{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Commande"|trans }} - GNT Pharma {% endblock %}
{% block promotion %}active{% endblock %}
{% block current_promotion %}active{% endblock %}

{% block body %}
<div class="container mt-4 fond-7 pb-3">
    <h3 class="mt-4 mb-5 fw-bold">
        <i class="fa fa-shopping-cart me-2"></i>
        {{ "Liste des promotions en cours"|trans }}
    </h3>

    {% for message in app.flashes('notice') %}
        <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            {{ message|trans }}
        </div>
    {% endfor %}

    <table class="table table-success-light table-bordered table-hover table-striped my-3" id="liste">
        <thead>
            <tr>
                <th>{{ 'Désignation'|trans }}</th>
                <th>{{ 'Date Début'|trans }}</th>
                <th>{{ 'Date Fin'|trans }}</th>
                <th>{{ 'Type'|trans }}</th>
                <th>{{ 'Actions'|trans }}</th>
            </tr>
        </thead>
        <tbody>
        {% for promotion in promotions %}
            <tr>
                <td>{{ promotion.designation }}</td>
                <td>{{ promotion.debut ? promotion.debut|date('d/m/Y') : '' }}</td>
                <td>{{ promotion.fin ? promotion.fin|date('d/m/Y') : '' }}</td>
                <td>{{ promotion.type }}</td>
                <td>
                    <a id="{{ promotion.id }}" onclick="load({{ promotion.id }})" class="btn btn-success" href="{{ path('promotion_show', {'id': promotion.id}) }}">
                        <i class="fa fa-list"></i>
                        {{ 'Afficher'|trans }}
                    </a>
                   {% if is_granted('ROLE_ADMIN') %}
                        {% if promotion.debut|date('Y-m-d') < 'now'|date('Y-m-d') and promotion.fin|date('Y-m-d') > 'now'|date('Y-m-d') and promotion.active != false %}
                            {{ include('promotion/admin/_arreter_form.html.twig') }}
                        {% endif %}
                        {{ include('promotion/admin/_delete_form.html.twig') }}
                   {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
 <div class="col-md-12 mt-5 mb-5 pt-2 pb-2 fond-7">
            <div class="centrer">
                <a target="__blank" href="{{ path('promotion_courante_pdf') }}"
                   class="btn btn-danger me-3">
                    <i class="fa fa-file-pdf"></i>
                    {{ "Vers Pdf"|trans }}
                </a>
            </div>
        </div>
{% endblock %}
