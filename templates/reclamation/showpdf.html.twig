<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #333;
        }

        /* ── En-tête ── */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #039c4f;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .header-table td { vertical-align: middle; border: none !important; }
        .logo { width: 80px; }
        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #039c4f;
            text-align: center;
        }
        .company-info {
            font-size: 10px;
            text-align: center;
            color: #555;
            line-height: 1.6;
        }

        /* ── Titre facture ── */
        .titre-facture {
            text-align: center;
            font-size: 15px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 16px 0 4px;
        }
        .sous-titre {
            text-align: center;
            font-size: 11px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        /* ── Tableaux ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
        }
        th, td {
            border: none;
            padding: 5px 6px;
            vertical-align: middle;
        }
        thead th {
            background-color: #c5fbae;
            color: #000;
            text-align: center;
            font-size: 10px;
        }
        tbody tr:nth-child(even) td {
            background-color: #f2f2f2;
        }
        td { font-size: 10px; }

        /* ── Tableau récap commande ── */
        .recap-wrapper {
            width: 75%;
            margin: 0 0 20px auto;
        }
        .recap-wrapper td { text-align: center; border: none; }

        /* ── Badge UG ── */
        .badge {
            background-color: #cc0000;
            color: #fff;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 9px;
            font-weight: bold;
        }

        /* ── Totaux ── */
        .text-end { text-align: right; }
        .text-center { text-align: center; }
        .fw-bold { font-weight: bold; }
        .text-nowrap { white-space: nowrap; }

        /* ── Montant en lettres ── */
        .montant-lettres {
            margin: 20px 0;
            font-size: 11px;
            line-height: 1.6;
        }

        /* ── Pied de page ── */
        .footer {
            margin-top: 30px;
            font-size: 9px;
            color: #888;
            text-align: center;
            border-top: 1px solid #ccc;
            padding-top: 8px;
        }
    </style>
</head>
<body>

{# ── En-tête société ── #}
<table class="header-table">
    <tr>
        <td style="width:90px;">
              {% if logoBase64 %}
    <img src="{{ logoBase64 }}" alt="Logo" style="width:80px;">
{% endif %}
        </td>
        <td style="text-align:center;vertical-align:middle;">
            <div class="company-name">GNT PHARMA</div>
            <div class="company-info">
                BP : 3582 Yaoundé – Cameroun, NGOUSSO<br>
                Montée Éleveur Immeuble Sainte Marie<br>
                +237 69 71 49 412 &nbsp;-&nbsp; +237 67 52 47 865<br>
                info@gnt-pharma.com &nbsp;-&nbsp; www.gnt-pharma.com<br>
                RCCM N° : RC/YAE/2023/M/105 &nbsp;-&nbsp; NIU : M122217881373Q
            </div>
        </td>
    </tr>
</table>

{# ── Titre ── #}
<div class="titre-facture"> {{ 'Réclamation'|trans }}</div>

              <table class="table table-success-light table-bordered table-hover mn-1">
        <thead>
        <tr>
            <th>{{'N° Commande'|trans}}</th>
            <th>{{ 'Date commande'|trans }}</th>
            <th>{{ 'Date Livraison'|trans }}</th>
        </tr>
        </thead>
         <thead>
        <tr>
            <td> 
                <button class="btn btn-success"
                        data-bs-toggle="modal" data-bs-target="#modal">
                    {{ reclamation.commande.id }}
                </a>
            </td>
            <td>{{ reclamation.commande.date|date("d/m/Y H:i:s") }}</td>
            <td>{{ reclamation.commande.dateefectlivraison|date("d/m/Y H:i:s") }}</td>
        </tr>
        </thead>
        </table>
             </div>
    </div>
        
        {% for reclamation in reclamations %}
    <table class="table table-success-light table-bordered table-hover table-striped mb-4 w-100">
         <thead>
        <tr>
            <th>{{'CIP'|trans}}</th>
            <th>{{ 'Désignation'|trans }}</th>
            <th>{{ 'N Lot'|trans }}</th>
            <th>{{ 'Peremption'|trans }}</th>
            <th>{{ 'Quantité Concernée'|trans }}</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>{{ reclamation.produit.reference }}</td>
            <td>{{ reclamation.produit.desigantion }}</td>
            <td>{{ reclamation.lot }}</td>
            <td>{{ reclamation.peremption|date("d/m/Y") }}</td>
            <td>{{ reclamation.quantite }}</td>
        </tr>
        <tr>
            <th>{{ 'Motif'|trans }}</th>
            <td colspan="4">{{ reclamation.motif }}</td>
        </tr>
        <tr>
            <th>{{ 'Commentaire'|trans }}</th>
            <td colspan="4">{{ reclamation.commentaire }}</td>
        </tr>
        </tbody>
        
    </table>
        {% endfor %}

</div>

<div class="container py-4">
    {% for reponse in reclamation.reponses %}
        <div class="row mt-4">

            {% if 'ROLE_CLIENT' in reponse.user.roles or 'ROLE_CLIENT_ADMIN' in reponse.user.roles %}

                <div class="col-md-7  py-4 fond-7">
                    {{ reponse.user.nom  }} | {{ reponse.date|date('d/m/Y H:i:s') }}
                    <hr class="text-secondaire">
                    {{ reponse.message }}
                </div>
                <div class="col-md-5"> </div>

            {% else %}
                <div class="col-md-5"> </div>
                <div class="col-md-7  py-4 fond-7">
                    {{ reponse.user.nom  }} | {{ reponse.date|date('d/m/Y H:i:s') }}
                    <hr class="text-secondaire">
                    {{ reponse.message }}
                </div>
            {% endif %}
        </div>
    {% else %}
    {% endfor %}

</body>
</html>
