{% extends
   
    'client.html.twig'
%}
{% block title %} {{ "Commande"|trans }} - GNT Pharma {% endblock %}
{% block reclamation %}active{% endblock %}
{% block new_retour %}active{% endblock %}

{% block body %}
    <div class="container mt-4 fond-7">
        <h3 class="mt-4 mb-5 fw-bold">
            <i class="fa fa-shopping-cart me-2"></i>
            {{ "Liste des dernieres commandes"|trans }}
        </h3>

        {% for message in app.flashes('notice') %}
            <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                {{ message|trans }}
            </div>
        {% endfor %}
        <table class="table table-success-light table-bordered table-hover table-striped w-100 mt-4" id="liste">
            <thead>
            <tr>
                <th>{{ 'Numéro Commande'|trans }}</th>
                <th>{{ 'Date de commande'|trans }}</th>
                <th>{{ 'Date de Livraison'|trans }}</th>
                <th> </th>
            </tr>
            </thead>
            <tbody>
            {% for commande in commandes %}
                <tr>
                    <td>{{ commande.id }}</td>
                    <td>{{ commande.date|date('d/m/Y') }}</td>
                    <td>{{ commande.dateefectlivraison ? commande.dateefectlivraison|date('d/m/Y') : '' }}</td>
                   
                    <td>
                        <a href="{{ path('reclamation_new', {'commande' : commande.id ,'user' : app.user.pharmacie.id}) }}" id="{{ commande.id }}" class="btn btn-success" onclick="load({{ commande.id }})">
                            <i class="fa fa-plus"></i>
                            {{ 'Nouvelle'|trans }}
                        </a>
                    </td>


                </tr>

            {% else %}

            {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
