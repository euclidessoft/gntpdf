{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Commande"|trans }} - GNT Pharma {% endblock %}
{% block produit %}active{% endblock %}
{% block all_produits %}active{% endblock %}

{% block body %}
<div class="col-lg-6 mt-4 p-3 fond-7">
    <h4 class="mt-4 mb-5 fw-bold">
        <i class="fa-brands fa-product-hunt me-2"></i>
        {{ "Détails Produit"|trans }}
    </h4>
    {% for message in app.flashes('notice') %}
    <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        {{ message|trans }}
    </div>
    {% endfor %}
    <table class="table table-success-light table-bordered table-hover table-striped">
            <tr>
                <th class="text-end">{{ 'Code Produit'|trans }}</th>
                <td class="text-start" data-label="Code Produit">{{ produit.reference }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Désigantion'|trans }}</th>
                <td class="text-start" data-label="DCI">{{ produit.desigantion }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'DCI'|trans }}</th>
                <td class="text-start" data-label="dci">{{ produit.dci }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Colisage'|trans }}</th>
                <td class="text-start" data-label="colisage">{{ produit.colisage }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Prix grossiste hors taxe'|trans }}</th>
                <td class="text-start" data-label="Prix grossiste hors taxe">{{ produit.pght|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Prix Cession'|trans }}</th>
                <td class="text-start" data-label="Prix Cession">{{ produit.prix|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Prix Public'|trans }}</th>
                <td class="text-start" data-label="Prix Public">{{ produit.prixpublic|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Commande minimum'|trans }}</th>
                <td class="text-start" data-label="Commande minimum">{{ produit.mincommande }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'Fabricant'|trans }}</th>
                <td class="text-start" data-label="Fabricant">{{ produit.fabriquant }}</td>
            </tr>
            <tr>
                <th class="text-end">{{ 'TVA'|trans }}</th>
                <td class="text-start" data-label="TVA">{{ produit.tva ? 'OUI' : 'NON' }}</td>
            </tr>
    </table>

    <div class="col-md-10 offset-md-2 mt-4 p-3 fond-7">
        <div class="centrer gap-3">
            {# {% if is_granted('ROLE_ADMIN') %} #}
            <a class="btn btn-success" href="{{ path('produit_edit', {'id': produit.id}) }}">
                <i class="fa fa-edit"></i> Modifier
            </a>
            {{ include('produit/admin/_delete_form.html.twig') }}
            {# {% endif %} #}
            <a id="{{ produit.id }}" onclick="load({{ produit.id }})" class="btn btn-success-light btn-normal" href="{{ path('produit_index') }}">
                <i class="fa fa-undo"></i>
                {{ 'Retour'|trans }}
            </a>
        </div>
    </div>

</div>
<div class="col-lg-6 mt-4 mb-5 p-3 fond-7">
    <h4 class="mt-4 mb-5 fw-bold">
        <i class="fa-brands fa-product-hunt me-2"></i>
        {{ "Fournisseurs ayant ce produit"|trans }}
    </h4>
    <table class="table table-success-light table-bordered table-hover table-striped my-3" id="liste">
        <thead>
            <tr>
                <th>{{'Désignation'|trans }}</th>
                <th>{{'Adresse'|trans }}</th>
                <th>{{'Email'|trans }}</th>
                <th>{{'Pays'|trans }}</th>
                <th>{{'Téléphone'|trans }}</th>
                <th>{{'Actions'|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for fournisseur in produit.fournisseurs %}
            <tr>
                <td data-label="Désignation">{{ fournisseur.designation }}</td>
                <td data-label="Adresse">{{ fournisseur.adresse }}</td>
                <td data-label="Email">{{ fournisseur.email }}</td>
                <td data-label="Pays">{{ fournisseur.pays }}</td>
                <td data-label="Téléphone">{{ fournisseur.telephone }}</td>
                <td data-label="Actions" class="text-center">
                    <a id="{{ fournisseur.id }}" onclick="load({{ fournisseur.id }})" href="{{ path('fournisseur_show', {'id': fournisseur.id}) }}" title="{{'Voir'|trans}}" class="btn btn-success">
                        <i class="fa fa-eye"></i>
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>


{% endblock %}