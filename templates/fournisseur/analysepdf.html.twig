<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #333;
        }

        /* ── En-tête ── */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #039c4f;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .header-table td { vertical-align: middle; border: none !important; }
        .logo { width: 80px; }
        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #039c4f;
            text-align: center;
        }
        .company-info {
            font-size: 10px;
            text-align: center;
            color: #555;
            line-height: 1.6;
        }

        /* ── Titre facture ── */
        .titre-facture {
            text-align: center;
            font-size: 15px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 16px 0 4px;
        }
        .sous-titre {
            text-align: center;
            font-size: 11px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        /* ── Tableaux ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
        }
        th, td {
            border: none;
            padding: 5px 6px;
            vertical-align: middle;
        }
        thead th {
            background-color: #c5fbae;
            color: #000;
            text-align: center;
            font-size: 10px;
        }
        tbody tr:nth-child(even) td {
            background-color: #f2f2f2;
        }
        td { font-size: 10px; }

        /* ── Tableau récap commande ── */
        .recap-wrapper {
            width: 75%;
            margin: 0 0 20px auto;
        }
        .recap-wrapper td { text-align: center; border: none; }

        /* ── Badge UG ── */
        .badge {
            background-color: #cc0000;
            color: #fff;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 9px;
            font-weight: bold;
        }

        /* ── Totaux ── */
        .text-end { text-align: right; }
        .text-center { text-align: center; }
        .fw-bold { font-weight: bold; }
        .text-nowrap { white-space: nowrap; }

        /* ── Montant en lettres ── */
        .montant-lettres {
            margin: 20px 0;
            font-size: 11px;
            line-height: 1.6;
        }

        /* ── Pied de page ── */
        .footer {
            margin-top: 30px;
            font-size: 9px;
            color: #888;
            text-align: center;
            border-top: 1px solid #ccc;
            padding-top: 8px;
        }
    </style>
</head>
<body>

{# ── En-tête société ── #}
<table class="header-table">
    <tr>
        <td style="width:90px;">
              {% if logoBase64 %}
    <img src="{{ logoBase64 }}" alt="Logo" style="width:80px;">
{% endif %}
        </td>
        <td style="text-align:center;vertical-align:middle;">
            <div class="company-name">GNT PHARMA</div>
            <div class="company-info">
                BP : 3582 Yaoundé – Cameroun, NGOUSSO<br>
                Montée Éleveur Immeuble Sainte Marie<br>
                +237 69 71 49 412 &nbsp;-&nbsp; +237 67 52 47 865<br>
                info@gnt-pharma.com &nbsp;-&nbsp; www.gnt-pharma.com<br>
                RCCM N° : RC/YAE/2023/M/105 &nbsp;-&nbsp; NIU : M122217881373Q
            </div>
        </td>
    </tr>
</table>

{# ── Titre ── #}
<div class="titre-facture">{{ 'Analyse Founisseur '|trans }}</div>
<div class="sous-titre">{{ day1|date('d/m/Y') }}
                    {{ 'au '|trans }} {{ day2|date('d/m/Y') }}</div>

           
               <table>
       
        <tbody>
            <tr>
                <th>{{"Compte"|trans}}</th>
                <th colspan="2">{{"fournisseur"|trans}}</th>
                {# <th>{{"designation"|trans}}</th> #}
                <th>{{"CA HT"|trans}}</th>
                <th>{{"Quantité Achetée"|trans}}</th>
            </tr>
        {% set total = 0 %}
        {% set totalca = 0 %}
        {% set totalquantite = 0 %}
            {% for fournisseur in fournisseurs %} 
                {% set totalcafournisseur = 0 %}
                {% set totalquantitefournisseur = 0 %}
                {% if fournisseur.produits|length > 0 %}
                <tr>
                {% set row = fournisseur.produits|length + 2 %}
                    <th>{{fournisseur.compte }}</th>
                    <th colspan='2'>{{fournisseur.designation }}
                    </th>
                    <td></td>
                    <td></td>
                </tr>
                 <tr>
                    <td  rowspan="{{row}}"></td>
                    <th colspan="2" class="text-center"> Produits </th>
                    <td></td>
                    <td></td>
                </tr>
                
                    {% for produit in fournisseur.produits %}
                    
                     <td>  {{ produit.reference}}</td>
                    <td> {{ produit.desigantion}} </td>
                   
                        {% set chiffre = AnalyseFournisseur(produit,fournisseur,day1,day2) %}
                         <td> {{ chiffre.ca|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} {% set totalcafournisseur = totalcafournisseur + chiffre.ca %}</td>
                         <td>  {{ chiffre.quantite|number_format(0, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} {% set totalquantitefournisseur = totalquantitefournisseur + chiffre.quantite %}</td>
                         </tr>
                    {% endfor %}
                    
                   <tr>
                    <th colspan="2" class="text-center"> Total</th>
                    <th>{{ totalcafournisseur|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} {% set totalca = totalca + totalcafournisseur%}</th>
                    <th> {{ totalquantitefournisseur|number_format(0, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} {% set totalquantite = totalquantite + totalquantitefournisseur%}</th>
                    </tr>

                    
                
                {% endif %}
            {% else %}
            {% endfor %}
        </tbody>
        <tfooter>
        <tr>
                    <th> </th>
                    <th colspan="2" class="text-center">Total General</th>
                    <th>{{ totalca|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} </th>
                    <th> {{ totalquantite|number_format(0, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} </th>
         </tr>
        </tfooter>

       </table> 
</body>
</html>

