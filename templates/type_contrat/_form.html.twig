{{ form_start(form, {'attr': {'id': 'form'}}) }}


    {% for message in app.flashes('notice') %}
        <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            {{ message|trans }}
        </div>
    {% endfor %}

<div class="row">
    <div class="col-12 mb-4">
        {{ form_row(form.type, {'attr': {'placeholder': 'Entrez le type de contrat *'}, 'label': 'Entrez le type de contrat *'}) }}
    </div>

    <div class="col-12 mb-4">
        {{ form_row(form.contenu, {'attr': {'placeholder': 'Contenu du contrat ... *','rows': 10}, 'label': 'Contenu du contrat'}) }}
    </div>
</div>

{{ form_rest(form) }}


{#{{ form_end(form) }}#}
