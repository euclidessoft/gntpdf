{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Commande"|trans }} - GNT Pharma {% endblock %}
{% block stock %}active{% endblock %}


{% block body %}
<div class="container mt-4 pb-4 fond-7">
    <h3 class="mt-4 mb-5 fw-bold">
        <i class="fa-brands fa-product-hunt me-2"></i>
        {{ "Détails Produit"|trans }}
    </h3>

    <table class="table table-success-light table-bordered table-hover table-striped w-100">
        <tbody>

        <tr>
            <th>{{'CIP'|trans}}</th>
            <td>{{ produit.reference }}</td>
        </tr>
        <tr>
            <th>{{'Désignation'|trans}}</th>
            <td>{{ produit.desigantion }}</td>
        </tr>
        <tr>
            <th>{{'DCI'|trans}}</th>
            <td>{{ produit.dci }}</td>
        </tr>
        <tr>
            <th>{{ 'Prix Cession'|trans }}</th>
            <td>{{ produit.prix|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
        </tr>
        <tr>
            <th>{{ 'Prix Public'|trans }}</th>
            <td>{{ produit.prixpublic|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
        </tr>
        <tr>
            <th>{{ 'Commande minimum'|trans }}</th>
            <td>{{ produit.mincommande }}</td>
        </tr>
        <tr>
            <th>{{ 'Fabricant'|trans }}</th>
            <td>{{ produit.fabriquant }}</td>
        </tr>
        </tbody>
    </table>


    <div class="col-md-6 offset-md-3 mt-4 py-3 fond-7">
        <div class="centrer">
            <a id="modif" onclick="load('modif')" class="btn btn-success me-3" href="{{ path('produit_edit', {'id': produit.id}) }}">
                <i class="fa fa-edit"></i>
                {{ 'Modifier'|trans }}

            </a>
            {{ include('produit/admin/_delete_form.html.twig') }}

            <a id="retour" onclick="load('retour')" class="btn btn-success ms-3" href="{{ path('produit_index') }}"><i class="fa fa-undo"></i>
                {{ 'Retour'|trans }}

            </a>

        </div>
    </div>

</div>
{% endblock %}
