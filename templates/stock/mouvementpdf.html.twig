<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #333;
        }

        /* ── En-tête ── */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #039c4f;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .header-table td { vertical-align: middle; border: none !important; }
        .logo { width: 80px; }
        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #039c4f;
            text-align: center;
        }
        .company-info {
            font-size: 10px;
            text-align: center;
            color: #555;
            line-height: 1.6;
        }

        /* ── Titre facture ── */
        .titre-facture {
            text-align: center;
            font-size: 15px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 16px 0 4px;
        }
        .sous-titre {
            text-align: center;
            font-size: 11px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        /* ── Tableaux ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
        }
        th, td {
            border: none;
            padding: 5px 6px;
            vertical-align: middle;
        }
        thead th {
            background-color: #c5fbae;
            color: #000;
            text-align: center;
            font-size: 10px;
        }
        tbody tr:nth-child(even) td {
            background-color: #f2f2f2;
        }
        td { font-size: 10px; }

        /* ── Tableau récap commande ── */
        .recap-wrapper {
            width: 75%;
            margin: 0 0 20px auto;
        }
        .recap-wrapper td { text-align: center; border: none; }

        /* ── Badge UG ── */
        .badge {
            background-color: #cc0000;
            color: #fff;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 9px;
            font-weight: bold;
        }

        /* ── Totaux ── */
        .text-end { text-align: right; }
        .text-center { text-align: center; }
        .fw-bold { font-weight: bold; }
        .text-nowrap { white-space: nowrap; }

        /* ── Montant en lettres ── */
        .montant-lettres {
            margin: 20px 0;
            font-size: 11px;
            line-height: 1.6;
        }

        /* ── Pied de page ── */
        .footer {
            margin-top: 30px;
            font-size: 9px;
            color: #888;
            text-align: center;
            border-top: 1px solid #ccc;
            padding-top: 8px;
        }
    </style>
</head>
<body>

{# ── En-tête société ── #}
<table class="header-table">
    <tr>
        <td style="width:90px;">
              {% if logoBase64 %}
    <img src="{{ logoBase64 }}" alt="Logo" style="width:80px;">
{% endif %}
        </td>
        <td style="text-align:center;vertical-align:middle;">
            <div class="company-name">GNT PHARMA</div>
            <div class="company-info">
                BP : 3582 Yaoundé – Cameroun, NGOUSSO<br>
                Montée Éleveur Immeuble Sainte Marie<br>
                +237 69 71 49 412 &nbsp;-&nbsp; +237 67 52 47 865<br>
                info@gnt-pharma.com &nbsp;-&nbsp; www.gnt-pharma.com<br>
                RCCM N° : RC/YAE/2023/M/105 &nbsp;-&nbsp; NIU : M122217881373Q
            </div>
        </td>
    </tr>
</table>


    <table>
        <tr>
            <th rowspan="2">Date</th>
            <th rowspan="2">Type</th>
            <th rowspan="2">Piece</th>
            <th rowspan="2">Tiers</th>
            <th colspan="2">Quantités en stock</th>
            <th rowspan="2">C.M.U.P. unitaire</th>
            <th rowspan="2">Stock permanent</th>
        </tr>
        <tr>
            <th>+/-</th>
            <th>Solde</th>
        </tr>
        
        {% set total = 0 %}
        {% for produit in produits %}
            <tr>
                <th>{{ produit.reference }}</th>
                <td></td>
                <td></td>
                <th>{{ produit.desigantion}}</th>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
            {% set stocks = mouvement(produit, day1, day2) %}
            {% set solde = 0%}
        {% set entree = 0%}
        {% set commande = 0%}
        {% set livre = 0%}
        {% set tableau = [] %}
        {% set totalprod = 0 %}
        {% for stock in stocks %}
            <tr>
                <td>{{ stock.date|date("d/m/Y") }}</td>
                <td>
                     {% if  stock.fournisseur is defined %}
                        appro.
                    {% else %}
                       liv.
                    {% endif %}
                </td>
                <td>
                     {% if  stock.fournisseur is defined %}
                        {{ stock.approvisionner.id }}
                    {% else %}
                        {{ stock.livrer.id }}
                    {% endif %}
                </td>
                <td>
                    {% if  stock.fournisseur is defined %}
                        {{ stock.fournisseur ? stock.fournisseur.designation : stock.approvisionner.retour.commande.user.nom }}
                    {% else %}
                        {{ stock.commande.user.nom }}
                    {% endif %}
                </td>
                <td>
                    {% if  stock.fournisseur is defined %}
                        {{ stock.quantite|number_format(0,',' , ' ') }}
                        {% set quantite = stock.quantite %}
                        {% set entree = entree + stock.quantite %}
                        {% set solde = solde + stock.quantite %}
                    
                    {% else %}
                     -   {{ stock.quantitelivrer|number_format(0,',' , ' ') }}
                      {% set quantite = stock.quantitelivrer %}
                       
                        {% set livre = livre + stock.quantitelivrer %}
                        {% set solde = solde - stock.quantitelivrer %}
                    {% endif %}
                </td>
                <td>
                    {{ solde|number_format(0,',' , ' ') }} 
                </td>
                <td>
                    {% if  stock.fournisseur is defined %}
                        
                     {{ stock.pght|number_format(2,',' , ' ')}} 
                    {% else %}
                     {{ stock.produit.prix|number_format(2,',' , ' ')}} 
                    {% endif %}
                  
                </td>
                <td>
                {% if  stock.fournisseur is defined %}
                        
                     {{ (stock.pght * quantite)|number_format(2,',' , ' ') }}
                    {% else %}
                        {{ (stock.produit.prix * quantite)|number_format(2,',' , ' ') }}
                    {% endif %}
                    
                </td>

            </tr>
        {% endfor %}
         <tr>
                <td></td>
                <td></td>
                <td></td>
                <th>Total {{ produit.reference}}</th>
                <th></th>
                <th>{{ solde|number_format(0,',' , ' ') }} </th>
                <th> </th>
                <th>
                {% set totalprod = solde * produit.prix %}
                 {% set total = total + totalprod %}
                 {{ totalprod|number_format(2,',' , ' ') }}
                 </th>
            </tr>
            
        {% endfor %}
         <tr>
               
                <th colspan="4" class="text-end">Total General</th>
                <th colspan="2"></th>
                <th> </th>
                <th>
                 {{ total|number_format(2,',' , ' ') }}
                 </th>
            </tr>
    </table>
</body>
</html>
