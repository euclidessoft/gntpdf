{% extends 'client.html.twig' %}
{% block title %} {{ "Bon de commande"|trans }} BC{{ commande.id }}{{ commande.numerofacture }} {% endblock %}
{% block commande %}active{% endblock %}
{% block my_commande %}active{% endblock %}

{% block body %}
    <div class="container mt-4 fond-7">
        <h3 class="mt-4 mb-5 fw-bold">
            <i class="fa fa-shopping-cart me-2"></i>
            {{ "Bon de commande"|trans }}
        </h3>

        <a href="#" onclick="history.back()" class="btn btn-success-light mb-3">
            <i class="fa fa-chevron-left"></i> {{ "Retour"|trans }}
        </a>
        <h4 class="text-center fw-bold text-uppercase mt-4">
            {{ ' Bon de commande'|trans }}
        </h4>
        <h6 class="text-center text-uppercase mb-3">
            {{ 'Numero'|trans }} : BC{{ commande.id }}{{ commande.numerofacture }}
        </h6>
        <div class="row my-5">
            <div class="col-5"></div>
            <div class="col-7">
                <table class="table table-success-light table-bordered table-hover table-striped text-center w-100">
                    <thead>
                    <tr>
                        <th>{{ 'Date'|trans }}</th>
                        <th>{{ 'N° Commande'|trans }}</th>
                        <th>{{ 'NIU'|trans }}</th>
                        <th>{{ 'RCCM'|trans }}</th>
                        {% if commande.credit == 1 and commande.payer == 0 %}
                            <th>{{ 'Echeance de paiement'|trans }}</th>
                        {% endif %}
                        <th>{{ 'Passé par'|trans }}</th>
                        {#            <th>Date de Livraison</th> #}
                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <td>{{ commande.date|date('d/m/Y H:m:s') }}</td>
                        <td>{{ commande.id }}</td>
                        <td>{{ commande.user.niu }}</td>
                        <td>{{ commande.user.rccm }}</td>
                        {% if commande.credit == 1 and commande.payer == 0 %}
                            <td>  {{ commande.echeance ? commande.echeance|date('d/m/Y'): '' }}</td>
                        {% endif %}
                        <td>{{ commande.pharmaemploye ? commande.pharmaemploye.nom ~" "~ commande.pharmaemploye.prenom : commande.user.nom ~" "~ commande.user.prenom }}</td>
                        {# <td class="fw-bold">
                        {% if commande.payer == 0 %}
                            <span class="text-danger">Non payée</span>
                        {% else %}
                            <span class="text-success">Payée</span>
                        {% endif %}
                    </td>
                                <td> </td> #}
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>
        {% set total=0 %}
        {% set reduction=0 %}
        {% set tva=0 %}
        <table class="table table-success-light table-bordered table-hover table-striped text-center">
            <thead>
            <tr>
                <th>{{ 'CIP'|trans }}</th>
                <th class="text-start">{{ 'Désignation'|trans }}</th>
                <th>{{ 'Quantité'|trans }}<br>{{ 'commandée'|trans }}</th>
                {#            <th>Quantite Livree</th>
                            <th>Quantite Restante</th>
                 <th>{{ 'Prix Cession'|trans }}</th>
                <th>{{ 'Réduction'|trans }}</th>
                <th>{{ 'TVA'|trans }}</th>
                <th>{{ 'Prix Public'|trans }}</th>
                <th>{{ 'Montant'|trans }}</th> #}
            </tr>
            </thead>
            <tbody>
            {% for commandeproduit in commandeproduits %}
                {% set reductionproduit = 0 %}
                <tr>
                    <td> {{ commandeproduit.produit.reference }} </td>
                    <td class="text-start">{{ commandeproduit.produit.desigantion }} </td>
                    <td>
                        {{ commandeproduit.quantite }}
                        {% if commandeproduit.ug != 0 %}
                            <span class="badge bg-danger">
                                        + {{ commandeproduit.ug }} U.G
                            </span>
                        {% endif %}
                    </td>
                    {#                <td>
                                    {{ commande.livraison ? commande.livrer.quantitelivrer : '' }}
                                    </td>
                                    <td> </td>
                     <td class="montant">
                        {{ commandeproduit.produit.prix|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}

                    </td>
                    <td>
                        {% if commandeproduit.promotion is not null %}
                            {% if commandeproduit.promotion.reduction is not null %}
                                {% set reductionproduit =  commandeproduit.quantite * commandeproduit.session * commandeproduit.promotion.reduction /100 %}

                                {% set reduction =  reduction + reductionproduit %}
                                <span class="badge bg-danger">
                                    -{{ commandeproduit.session * commandeproduit.promotion.reduction /100 }} F
                            </span>
                            {% else %}
                                -
                            {% endif %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        {% if commandeproduit.tva != 0 %}
                            {% set tva = tva + (((commandeproduit.quantite * commandeproduit.session) - reductionproduit) * 0.1925) %}
                            {% if commandeproduit.promotion is not null %}
                                {% if commandeproduit.promotion.reduction is not null %}
                                    {{ (commandeproduit.session - (commandeproduit.session * commandeproduit.promotion.reduction /100)) * 0.1925 }}
                                {% else %}
                                    {{ commandeproduit.session  * 0.1925 }}
                                {% endif %}
                            {% else %}
                                {{ commandeproduit.session  * 0.1925 }}
                            {% endif %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td class="montant">{{ commandeproduit.produit.prixpublic|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td class="montant">
                        {{ (commandeproduit.quantite * commandeproduit.produit.prix)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                        {% set total = total + (commandeproduit.quantite * commandeproduit.produit.prix) %}
                    </td> #}
                </tr>
            {% endfor %}
            {# <tr>
                <td colspan="7" class="text-end">
                    {{ "Total HT"|trans }}
                </td>
                <td class="montant">
                    <span id="" class="text-nowrap">{{ total|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                </td>
            </tr>
            {% if reduction != 0 %}
                <tr>
                    <td colspan="7" class="text-end">
                        {{ "Total Réduction"|trans }}
                    </td>
                    <td class="montant">
                        <span id="" class="text-nowrap">{{ reduction|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                    </td>
                </tr>
            {% endif %}
            <tr>
                <td colspan="7" class="text-end">
                    {{ "Total TVA"|trans }}
                </td>
                <td class="montant">
                    <span id="" class="text-nowrap">{{ tva|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                </td>
            </tr>
            <tr>
                <td colspan="7" class="text-end">
                    {{ "Prélèvement (2%)"|trans }}
                </td>
                <td class="text-center">
               
                    <span id="">{{ commande.acompte != 0 ? commande.acompte|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') : ''}}</span>
                    <input type="hidden" value="{{ tva }}" id="totaltamp"/>
                </td>
            </tr>

            <tr class="fw-bold">
                <td colspan="7" class="text-end">
                    {{ "Net à payer"|trans }}
                </td>
                <td class="montant">
                    <span class="text-nowrap">{{ (total + commande.acompte + tva - reduction)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                          <span id="total" class="text-nowrap" style="display:none;">{{ (total + commande.acompte + tva - reduction)|number_format(2, '.' , '') }}</span>
                </td>
            </tr> #}
            </tbody>
        </table>


    </div>
    <div class="container mb-5 p-3 fond-5">
        <div class="centrer gap-3">
            <a
                    href="{{ path('commande_panier_print_Bon',{'commande': commande.id }) }}"
                    class="btn btn-success float-end">
                <i class="fa fa-print"></i>
                {{ "Imprimer"|trans }}
            </a>
            <a target="_blank" href="{{ path('commande_panier_bon_pdf',{'commande': commande.id }) }}"
               class="btn btn-danger">
                <i class="fa fa-file-pdf"></i>
                {{ "Vers Pdf"|trans }}
            </a>
        </div>
    </div>

{% endblock %}
