{% extends 'client.html.twig' %}
{% block title %} {{ "Commande"|trans }} - GNT Pharma {% endblock %}
{% block commande %}active{% endblock %}
{% block my_commande %}active{% endblock %}

{% block body %}
<div class="container mt-4 fond-7">
    <h3 class="mt-4 mb-5 fw-bold">
        <i class="fa fa-shopping-cart me-2"></i>
        {{ "Historique des commandes"|trans }}
    </h3>
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link" href="{{ path('commande_panier_suivi') }}">
                {{'En attente de validation'|trans }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" href="#">
            {% if is_granted("ROLE_CLIENT_ADMIN")%}
                {{'Commandes déjà payées'|trans}}
                {% else %}
                 {{'Commandes déjà validées'|trans}}
                {% endif %}
            </a>
        </li>
    </ul>
    {% for message in app.flashes('notice') %}
        <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            {{ message|trans }}
        </div>
    {% endfor %}
    <table class="table table-success-light table-bordered table-hover table-striped w-100 my-4 text-center" id="liste">
        <thead>
        <tr>
            <th>{{ 'Numero Commande'|trans }}</th>
            {% if is_granted("ROLE_CLIENT_ADMIN") %}
                <th>{{ 'Passée par'|trans }}</th>
            {% endif %}
            <th>{{ 'Date de commande'|trans }}</th>
            <th>{{ 'Date de Livraison'|trans }}</th>
{#            <!-- <th>{{ 'Client'|trans }} </th> -->#}
            {% if is_granted("ROLE_CLIENT_ADMIN")%} <th>{{ 'Montant'|trans }}</th> {% endif %}
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for commande in commandes %}
            <tr>
                <td>{{ commande.id }}</td>
                {% if is_granted("ROLE_CLIENT_ADMIN") %}
                    <td>{{ commande.pharmaemploye ? commande.pharmaemploye.nom ~" "~ commande.pharmaemploye.prenom : "" }}</td>
                {% endif %}
                <td>{{ commande.date|date('d/m/Y H:s:i') }}</td>
                <td>{{ commande.datelivrer ? commande.datelivrer|date('d/m/Y H:s:i') : '' }}</td>
{#                <!-- <td> {{ commande.user.nom }}</td> -->#}
                 {% if is_granted("ROLE_CLIENT_ADMIN")%}
                    <td>{{ commande.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                {% endif %}
                <td>
                        <a id="{{ commande.id }}" onclick="load({{ commande.id }})" href="{{ path('commande_panier_Detail', {'commande' : commande.id}) }}" class="btn btn-success">
                        <i class="fa fa-money-bill"></i>
                            {{ 'Facture'|trans }}
                        </a>

                         <a id="b{{ commande.id }}" onclick="load('b{{ commande.id }}')" href="{{ path('commande_panier_bon', {'commande' : commande.id}) }}" class="btn btn-success">
                        <i class="fa fa-list"></i>
                            {{ 'Bon de commande'|trans }}
                        </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
