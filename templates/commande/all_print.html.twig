<!doctype html>
<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <title>&nbsp;</title>
    <style>
        .titre {
            font-family: Verdana, Geneva, Tahoma, sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #039c4f;
        }

        .text {
            font-size: 14px;
        }

        .badge {
            background-color: red !important;
        }

        @media print {
            .table-success-light {
                color: #000 !important;
            }

            .table-bordered {
                border: 1px solid #000 !important;
            }

            thead {
                background-color: #c5fbae !important;
                color: #000;
            }

            .tt {
                display: inline-block;
                border: none;
                width: 180px !important;
            }
        }
    </style>

</head>
<body>
{#<div style="width: 100%;padding-right: var(--bs-gutter-x, 0.75rem);padding-left: var(--bs-gutter-x, 0.75rem);margin-right: auto;margin-left: auto;">#}
{#    <div style="flex: 0 0 auto;width: 66.66666667%;margin-left: 16.66666667%;">#}

<table style="font-family: Verdana, Geneva, Tahoma, sans-serif;width: 100%;text-align: center">
    <tr>
        <td style="width:25%" rowspan="5">
            <img src="https://gnt-pharma.com/images/gntpharma.jpeg" alt="Logo" class="w-100">

        </td>
        <td style="width:75%;font-size: 30px;font-weight: bolder;color: #039c4f;">
            GNT PHARMA
        </td>
    </tr>
    <tr>
        <td>BP : 3582 Yaoundé – Cameroun, NGOUSSO
            <br>
            Montée Éleveur Immeuble Sainte Marie</td>
    </tr>
    <tr>
        <td>+237 69 71 49 4 12 / +237 67 52 47 865</td>
    </tr>
    <tr>
        <td>info@gntpharma-cameroun.com / www.gnt-pharma.com</td>
    </tr>
    <tr>
        <td>RCCM N° : RC/YAE/2023/M/105 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;NIU : M122217881373Q</td>
    </tr>
</table>
        <div style="border-bottom: 2px solid #039c4f;padding-bottom: 20px;">

        </div>
        <h3 style="font-size: 25px;text-align: center !important;font-weight: bold;text-transform: uppercase !important;margin-top: 1.5rem !important;">
            {{ ' Facture'|trans }}
        </h3>
        <h6 style="text-align: center !important;font-weight: bold;text-transform: uppercase !important;margin-bottom: 2rem !important;">
            {{ 'Numero'|trans }} : {{ commande.id }}-{{ commande.numerofacture }}
        </h6>
                <table style="width: 60%;margin-bottom: 3rem;vertical-align: center;color: #000 !important;text-align: center !important;border-collapse: collapse;margin-left: auto;margin-right: 0">
                    <thead>
                    <tr>
                        <th style="border: 1px solid #000;padding:5px;">{{ 'Numero'|trans }} <br>{{ 'Commande'|trans }}</th>
                        <th style="border: 1px solid #000;padding:5px;">{{ 'Date'|trans }}</th>
                        <th style="border: 1px solid #000;padding:5px;">{{ 'Client'|trans }}</th>
                        <th style="border: 1px solid #000;padding:5px;">{{ 'NIU'|trans }}</th>
                        {% if commande.credit == 1 and commande.payer == 0 %}
                            <th style="border: 1px solid #000;padding:5px;">
                                {{ 'date d\'echeance de paiement'|trans }}
                            </th>
                        {% endif %}

                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <td style="border: 1px solid #000;padding:5px;">{{ commande.id }}</td>
                        <td style="border: 1px solid #000;padding:5px;">{{ commande.date|date('d/m/Y') }}</td>
                        <td style="border: 1px solid #000;padding:5px;">{{ commande.user.nom }}</td>
                        <td style="border: 1px solid #000;padding:5px;">{{ commande.user.niu }}</td>
                        {% if commande.credit == 1 and commande.payer == 0 %}
                            <td style="border: 1px solid #000;padding:5px;"> {{ commande.echeance ? commande.echeance|date('d/m/Y'): ''  }}</td>
                        {% endif %}
                    </tr>
                    </tbody>
                </table>
        {% set total=0 %}
        {% set reduction=0 %}
        {% set tva=0 %}
        <table style="border-collapse: collapse;width: 100% !important;margin-bottom: 3rem !important;">
            <thead>
            <tr>
                <th style="border: 1px solid #000;padding:5px;">{{ 'CIP'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;" class="tt">{{ 'Désignation'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;">{{ 'Qté'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;">{{ 'Prix Ces.'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;">{{ 'Réduc.'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;">{{ 'TVA'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;">{{ 'Prix Public'|trans }}</th>
                <th style="border: 1px solid #000;padding:5px;">{{ 'Montant'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for commandeproduit in commandeproduits %}
                {% set ug = commandeproduit.ug %}
                {% set reductionproduit = 0 %}
                <tr>
                    <td style="border: 1px solid #000;padding:5px;"> {{ commandeproduit.produit.reference }} </td>
                    <td style="border: 1px solid #000;padding:5px;">{{ commandeproduit.produit.desigantion }} </td>
                    <td style="border: 1px solid #000;padding:5px;">
                        {{ commandeproduit.quantite }}
                        {% if commandeproduit.ug != 0 %}
                            <span class="badge bg-danger" style="">
                                    + {{ commandeproduit.ug }} U.G
                        </span>
                        {% endif %}
                    </td>
                    <td style="white-space: nowrap !important;border: 1px solid #000;padding:5px;">
                        {{ commandeproduit.produit.prix|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}

                    </td>
                    <td style="border: 1px solid #000;padding:5px;">
                        {% if commandeproduit.promotion is not null %}
                            {% if commandeproduit.promotion.reduction is not null %}
                                {% set reductionproduit =  commandeproduit.quantite * commandeproduit.session * commandeproduit.promotion.reduction /100 %}

                                {% set reduction =  reduction + reductionproduit %}
                                <span style="display: inline-block; padding: 0.35em 0.65em; font-size: 0.75em; font-weight: 700; line-height: 1; color: #fff; text-align: center; white-space: nowrap; vertical-align: baseline; border-radius: 0.25rem;background-color: #dc3545 !important;">
                                    -{{ commandeproduit.session * commandeproduit.promotion.reduction /100 }} F
                                </span>
                            {% else %}
                                -
                            {% endif %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td style="white-space: nowrap !important;border: 1px solid #000;padding:5px;">
                        {% if commandeproduit.produit.tva == 1 %}
                            {% set tva = tva + (((commandeproduit.quantite * commandeproduit.session) - reductionproduit) * 0.1925) %}
                            {% if commandeproduit.promotion is not null %}
                                {% if commandeproduit.promotion.reduction is not null %}
                                    {{ (commandeproduit.session - (commandeproduit.session * commandeproduit.promotion.reduction /100)) * 0.1925 }}
                                {% else %}
                                    {{ commandeproduit.session  * 0.1925 }}
                                {% endif %}
                            {% else %}
                                {{ commandeproduit.session  * 0.1925 }}
                            {% endif %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td style="border: 1px solid #000;padding:5px;white-space: nowrap">{{ commandeproduit.produit.prixpublic|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td style="white-space: nowrap !important;text-align: right !important;border: 1px solid #000;padding:5px;">
                        {{ (commandeproduit.quantite * commandeproduit.produit.prix)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                        {% set total = total + (commandeproduit.quantite * commandeproduit.produit.prix) %}
                    </td>
                </tr>

            {% else %}
                <tr>
                    <td colspan="10">{{ 'Aucune commande'|trans }}</td>
                </tr>
            {% endfor %}
            <tr>
                <td colspan="7" style="border: 1px solid #000;padding:5px;text-align: right !important;font-weight: bolder !important;white-space: nowrap !important;">
                    {{ "Total HT"|trans }}
                </td>
                <td style="text-align: right !important;border: 1px solid #000;padding:5px;">
                    <span id="" style="font-weight: bolder !important;white-space: nowrap !important;">
                        {{ total|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                    </span>
                </td>
            </tr>
            {% if reduction != 0 %}
                <tr>
                    <td colspan="7" style="border: 1px solid #000;padding:5px;text-align: right !important;font-weight: bolder !important;white-space: nowrap !important;">
                        {{ "Total Réduction"|trans }}
                    </td>
                    <td style="border: 1px solid #000;padding:5px;">
                        <span id="" style="font-weight: bolder !important;">
                            {{ reduction|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                        </span>
                    </td>
                </tr>
            {% endif %}
            <tr>
                <td colspan="7" style="border: 1px solid #000;padding:5px;text-align: right !important;white-space: nowrap !important;">
                    {{ "Total TVA"|trans }}
                </td>
                <td style="border: 1px solid #000;padding:5px;text-align: right !important;white-space: nowrap !important;">
                    <span id="">
                        {{ tva|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                    </span>
                </td>
            </tr>
            <tr>
                <td colspan="7" style="border: 1px solid #000;padding:5px;text-align: right !important;">
                    {{ "Prélèvement (2%)"|trans }}
                </td>
                <td style="border: 1px solid #000;padding:5px;text-align: right !important;">
                        {{ commande.acompte != 0 ? commande.acompte|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') : '' }}
                    <input type="hidden" value="{{ tva }}" id="totaltamp"/>
                </td>
            </tr>

            <tr>
                <td colspan="7" style="border: 1px solid #000;padding:5px;text-align: right !important;font-weight: bolder !important;white-space: nowrap !important;">
                    {{ "Net à payer"|trans }}
                </td>
                <td class="fw-bolder text-nowrap" style="border: 1px solid #000;padding:5px;text-align: right !important;white-space: nowrap !important;font-weight: bolder;">
                        {{ (total + commande.acompte + tva - reduction)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                    <span id="total" style="border: 1px solid #000;padding:5px;display:none;white-space: nowrap !important;">
                        {{ (total + commande.acompte + tva - reduction)|number_format(2, '.' , '') }}
                    </span>
                </td>
            </tr>
            </tbody>
        </table>
        {# Conversion prix en lettre #}
        <div style="margin-top: 3rem !important;">
            {{ 'Arrêtée la présente à la somme de '|trans }} <b id="conversion"></b><b id="virgule"></b> <b>franc CFA
                TTC</b>
        </div>
        {# /***** end*****/ #}
{# 
        {{ include('includes/javascript.html.twig') }}
        <script>
            {{ include('includes/impression.html.twig') }}


            // Quand l'impression est terminée
            window.onafterprint = function () {
                document.location.href = '{{ path('commande_panier_Detail',{'commande': commande.id}) }}'
            };
        </script> #}
</body>

</html>
