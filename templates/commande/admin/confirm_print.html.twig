<!doctype html>
<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <title>&nbsp;</title>
    <style>
        .titre {
            font-family: Verdana, Geneva, Tahoma, sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #039c4f;
        }

        .text {
            font-size: 14px;
        }

        .badge {
            background-color: red !important;
        }

        @media print {
            .table-success-light {
                color: #000 !important;
            }

            .table-bordered {
                border: 1px solid #000 !important;
            }

            thead {
                background-color: #c5fbae !important;
                color: #000;
            }

            .tt {
                display: inline-block;
                border: none;
                width: 180px !important;
            }
        }
    </style>

</head>
<body>
<div class="container-fluid">


    <div class="col-lg-8 offset-lg-2">
        <div class="row" style="border-bottom: 1px solid #039c4f;padding-bottom: 20px;">
            <div class="col-2">
                <img src="{{ asset('images/gntpharma.jpeg') }}" alt="Logo" class="w-100">
            </div>
            <div class="col-10 text-center">
                <div class="row">
                    <div class="col-12 titre text-center">
                        GNT PHARMA
                    </div>
                    <div class="col-12 text">
                        BP : 3582 Yaoundé – Cameroun, NGOUSSO
                        <br>
                        Montée Éleveur Immeuble Sainte Marie
                    </div>
                    <div class="col-12 text">
                        +237 69 71 49 4 12 / +237 67 52 47 865
                    </div>
                    <div class="col-12 text">
                        info@gntpharma-cameroun.com / www.gnt-pharma.com
                    </div>
                    <div class="col-12 text">
                        RCCM N° : RC/YAE/2023/M/105 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;NIU : M122217881373Q
                    </div>
                    <div class="col-12 text">
                       SARL au CAPITAL de 100 000 000 F CFA
                    </div>
                    <!-- <div class="col-12 fw-bold">
                    </div> -->
                </div>
            </div>
        </div>
          <h3 class="text-center fw-bold text-uppercase mt-4">
            {{ ' Facture'|trans }}
        </h3>
        <h6 class="text-center fw-bold text-uppercase mb-3">
        {{ 'Numero'|trans }} : {{ commande.id}}-{{ commande.numerofacture }}
        </h6>

        <div class="row">
            <div class="col-12">
                <table class="table table-success-light text-center table-bordered">
                    <thead>
                    <tr>
                        <th>{{ 'Numero'|trans }} <br>{{ 'Commande'|trans }}</th>
                        <th>{{ 'Date'|trans }}</th>
                        <th>{{ 'Client'|trans }}</th>
                        <th>{{ 'NIU'|trans }}</th>
                        {% if commande.credit == 1 and commande.payer == 0 %}
                        <th>{{ 'date d\'echeance de paiement'|trans }}</th>
                        {% endif %}

                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <td>{{ commande.id }}</td>
                        <td>{{ commande.date|date('d/m/Y') }}</td>
                        <td>{{ commande.user.nom }}</td>
                        <td>{{ commande.user.niu }}</td>
                         {% if commande.credit == 1 and commande.payer == 0 %}
                             <td> {{ commande.echeance ? commande.echeance|date('d/m/Y'): ''  }}</td>
                        {% endif %}
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>
        {% set total=0 %}
        {% set reduction=0 %}
        {% set tva=0 %}
        <table class="table table-success-light text-center table-bordered mt-2 w-100">
            <thead>
            <tr>
                <th>{{ 'N° Prod'|trans }}</th>
                <th class="tt">{{ 'Désignation'|trans }}</th>
                <th>{{ 'Qté Cdée'|trans }}</th>
                <th>{{ 'Qté Lrée'|trans }}</th>
                <th>{{ 'Prix Ces.'|trans }}</th>
                <th>{{ 'Réduc.'|trans }}</th>
                <th>{{ 'TVA'|trans }}</th>
                <th>{{ 'Prix Public'|trans }}</th>
                <th>{{ 'Montant'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for commandeproduit in commandeproduits %}
             {% set ug = 0 %}
                {% set reductionproduit = 0 %}
                <tr>
                    <td> {{ commandeproduit.produit.id }} </td>
                    <td class="tt">{{ commandeproduit.produit.desigantion }} </td>
                <td>
                        {{ commandeproduit.quantitecommande ? commandeproduit.quantitecommande : commandeproduit.quantite }}
                        {% if commandeproduit.ug != 0 %}
                            <span class="badge bg-danger">
                                <br>
                                + {{ commandeproduit.ug }} U.G
                            </span>
                        {% endif %}

                    </td>
                    <td>
                        {% if commande.suivi %}
                            {{ commandeproduit.quantite }}
                        {% else %}
                            {% if commandeproduit.produit.stock > commandeproduit.quantite %}
                                {{ commandeproduit.quantite }}
                            {% else %}
                                {{ commandeproduit.produit.stock }}
                            {% endif %}
                        {% endif %}
                        
                    </td>
                    <td class="text-nowrap">
                        {{ commandeproduit.produit.prix|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}

                    </td>
                    <td>
                        {% if commandeproduit.promotion is not null %}
                            {% if commandeproduit.promotion.reduction is not null %}
                                {% set reductionproduit =  commandeproduit.quantite * commandeproduit.session * commandeproduit.promotion.reduction /100 %}

                                {% set reduction =  reduction + reductionproduit %}
                                <span class="badge bg-danger">
                                    -{{ commandeproduit.session * commandeproduit.promotion.reduction /100 }} F
                            </span>
                            {% else %}
                                -
                            {% endif %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td class="text-nowrap">
                        {% if commandeproduit.tva != 0 %}
                            {% set tva = tva + (((commandeproduit.quantite * commandeproduit.session) - reductionproduit) * 0.1925) %}
                            {% if commandeproduit.promotion is not null %}
                                {% if commandeproduit.promotion.reduction is not null %}
                                    {{ (commandeproduit.session - (commandeproduit.session * commandeproduit.promotion.reduction /100)) * 0.1925 }}
                                {% else %}
                                    {{ commandeproduit.session  * 0.1925 }}
                                {% endif %}
                            {% else %}
                                {{ commandeproduit.session  * 0.1925 }}
                            {% endif %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>{{ commandeproduit.produit.prixpublic|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td class="text-nowrap text-end">
                        {{ (commandeproduit.quantite * commandeproduit.produit.prix)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                        {% set total = total + (commandeproduit.quantite * commandeproduit.produit.prix) %}
                    </td>
                </tr>
            {% endfor %}
            <tr>
                <td colspan="8" class="text-end fw-bolder">
                    {{ "Total HT"|trans }}
                </td>
                <td class="text-end text-nowrap">
                    <span id=""
                          class="fw-bolder">{{ total|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                </td>
            </tr>
            {% if reduction != 0 %}
                <tr>
                    <td colspan="8" class="text-end fw-bolder">
                        {{ "Total Réduction"|trans }}
                    </td>
                    <td>
                        <span id=""
                              class="fw-bolder">{{ reduction|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                    </td>
                </tr>
            {% endif %}
            <tr>
                <td colspan="8" class="text-end fw-bolder">
                    {{ "Total TVA"|trans }}
                </td>
                <td class="text-end">
                    <span id="">{{ tva|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                </td>
            </tr>
            <tr>
                <td colspan="8" class="text-end">
                    {{ "Prélèvement (2%)"|trans }}
                </td>
                <td class="text-center">
                
                    <span id="">{{ commande.acompte != 0 ? commande.acompte|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') : ''}}</span>
                    <input type="hidden" value="{{ tva }}" id="totaltamp"/>
                </td>
            </tr>

            <tr>
                <td colspan="8" class="text-end fw-bolder text-nowrap">
                    {{ "Net à payer"|trans }}
                </td>
                <td class="fw-bolder text-nowrap">
                    <span class="text-nowrap">{{ (total + commande.acompte + tva - reduction)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                    <span id="total" class="text-nowrap"
                          style="display:none;">{{ (total + commande.acompte + tva - reduction)|number_format(2, '.' , '') }}</span>
                </td>
            </tr>
            </tbody>
        </table>
        {#Conversion prix en lettre #}
        <div class="mt-5">
            {{ 'Arrêtée la présente à la somme de'|trans }}&nbsp;<b id="conversion"></b><b id="virgule"></b>
            <b>{{ 'francs CFA TTC'|trans }}</b>
        </div>
        {#/***** end*****/#}
        {{ include('includes/javascript.html.twig') }}
        <script>
            {{ include('includes/impression.html.twig') }}

            // Quand l'impression est terminée
            window.onafterprint = function () {
                document.location.href = '{{ path('commande_panier_paiement',{'commande': commande.id}) }}'
            };
        </script>
    </div>
</div>
</body>

</html>
