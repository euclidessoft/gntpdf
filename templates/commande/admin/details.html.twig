    <table class="table table-success-light table-bordered table-hover table-striped w-100 my-4" id="facture"
           style="display:none;">
        <thead>
        <tr>
            <th>{{ 'Date'|trans }}</th>
            <th>{{ 'Numero Facture'|trans }}</th>
            <th>{{ 'Numero Ligne'|trans }}</th>
            <th>{{ 'Code Interne'|trans }}</th>
            <th>{{ 'Code Cip'|trans }}</th>
            <th>{{ 'Code CIP Alternatif'|trans }}</th>
            <th>{{ 'Description'|trans }}</th>
            <th>{{ 'Laboratoire'|trans }}</th>
            <th>{{ 'Quantite Demandee'|trans }}</th>
            <th>Quantitee livree</th>
            <th>Unite Gratuite</th>
            <th>{{ 'Prix de Cession Hors Taxe'|trans }}</th>
            <th>{{ 'Taux Taxe'|trans }}</th>
            <th>{{ 'Prix public'|trans }}</th>
            <th>{{ 'Prix TTC'|trans }}</th>
        </tr>
        </thead>
        <tbody>
        {% for commandeproduit in commandeproduits %}
            {% set reductionproduit = 0 %}
            <tr>
                <td> {{ commande.date|date('d/m/Y') }} </td>
                <td> {{ commande.id }}-{{ commande.numerofacture }} </td>
                <td></td>
                <td> {{ commandeproduit.produit.id }} </td>
                <td> {{ commandeproduit.produit.reference }} </td>
                <td> {{ commandeproduit.produit.alternatif }} </td>
                <td> {{ commandeproduit.produit.desigantion }} </td>
                <td> {{ commandeproduit.produit.Fabriquant }} </td>
                <td>
                    {{ commandeproduit.quantite }}

                </td>
                {#                <td> #}
                {#                {{ commande.livraison ? commande.livrer.quantitelivrer : '' }} #}
                {#                </td> #}
                {#                <td> </td> #}
                <td>
                    {# determination quantite livreee #}
                    {% set quantite = 0 %}
                    {% for livrerproduit  in livrerproduits %}
                        {% if livrerproduit.commande.id  == commande.id and livrerproduit.produit.id == commandeproduit.produit.id %}
                            {% set quantite = quantite + livrerproduit.quantitelivrer %}
                        {% endif %}

                    {% else %}
                    {% endfor %}
                    {{ quantite != 0 ? quantite : '' }}

                </td>
                <td>
                    {% if commandeproduit.ug != 0 %}
                        <span class="badge bg-danger">
                                        + {{ commandeproduit.ug }} U.G
                            </span>
                    {% endif %}
                </td>
                <td>
                    {{ commandeproduit.session }}

                </td>
                <td>
                    {% set tva= 0 %}
                    {% if commandeproduit.produit.tva is true %}
                        19,25 {% set tva= 0.1925 %}%
                    {% else %}
                        {{ tva }}%
                    {% endif %}
                </td>
                <td>{{ commandeproduit.publique }}</td>
                <td>
                    {% if commandeproduit.tva != 0 %}
                        {{ commandeproduit.publique + commandeproduit.publique * tva }}
                    {% else %}
                        {{ commandeproduit.session }}
                    {% endif %}

                </td>

            </tr>
        {% endfor %}
        <tbody>

    </table>
    <input type="hidden" id="numfact" value="{{ commande.id }}-{{ commande.numerofacture }}"/>
    <div class="container mb-5 fond-5">
        <div class="centrer gap-3">
            <a id="print" href="{{ path('commande_panier_print_Detail',{'commande': commande.id }) }}"
               class="btn btn-success">
                <i class="fa fa-print"></i>
                {{ "Imprimer"|trans }}
            </a>
            <a id="print" target="_blank"
               href="{{ path('commande_panier_print_Detail_pdf',{'commande': commande.id }) }}"
               class="btn btn-danger">
                <i class="fa fa-file-pdf"></i>
                {{ "Vers Pdf"|trans }}
            </a>
            <span id="exportexcel" class=""></span>
        </div>
    </div>

{% endblock %}