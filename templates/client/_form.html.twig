<div class="col-lg-12 mt-3">
    {{ form_start(form, {'attr' : { 'id' : 'form'}}) }}

    <div class="row">
        <div class="col-md-6">
            {{ form_errors(form.prenom) }}
        </div>
        <div class="col-md-6">
            {{ form_errors(form.nom) }}
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.prenom, {'label': 'Prénom *', 'attr' : { 'placeholder' : 'Prénom *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.nom, {'label': 'Nom *', 'attr' : { 'placeholder' : 'Nom *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            {{ form_errors(form.email) }}
        </div>
        <div class="col-md-6">
            {{ form_errors(form.phone) }}
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.email, {'label': 'Email *', 'attr' : { 'placeholder' : 'Email *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.phone, {'label': 'Telephone *', 'attr' : { 'placeholder' : 'Telephone *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            {{ form_errors(form.niu) }}
        </div>
        <div class="col-md-6">
            {{ form_errors(form.boitepostale) }}
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.niu, {'label': 'NIU', 'attr' : { 'placeholder' : 'NIU *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.boitepostale, {'label': 'Boite Postale', 'attr' : { 'placeholder' : 'Boite Postale *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            {{ form_errors(form.rccm) }}
        </div>
        <div class="col-md-6">
            {{ form_errors(form.siteweb) }}
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.rccm, {'label': 'RCCM', 'attr' : { 'placeholder' : 'RCCM *'}}) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group mb-4">
                {{ form_row(form.siteweb, {'label': 'Site web', 'attr' : { 'placeholder' : 'Site web *'}}) }}
            </div>
        </div>
        <div class="col-md-12">
            {{ form_errors(form.adresse) }}
        </div>
        <div class="col-md-12">
            <div class="form-group mb-4">
                {{ form_row(form.adresse, {'label': 'Adresse *', 'attr' : { 'placeholder' : 'Adresse '}}) }}
            </div>
        </div>
    </div>
    {{ form_rest(form) }}


    <div class="col-md-8 col-sm-12 mt-4 p-3 fond-7">
        <div class="centrer mx-3">
            <button type="submit" class="btn btn-shadow btn-normal btn-success me-3">
                <i class="fa fa-save"></i>
                {{ 'Enregistrer'|trans }}
            </button>
            <a {#id="annule" onclick="load('annule')"#} href="{{ path('client_index') }}" class="btn btn-shadow btn-normal btn-success-light">
                <i class="fa fa-undo"></i>
                {{ 'Annuler'|trans }}
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>