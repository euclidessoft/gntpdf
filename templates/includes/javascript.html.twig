            if (quantite != $('#quant' + id).val()) {
                $('#btn' + id).html("<i class='fa-solid fa-spinner fa-spin-pulse fa-lg'></i>");
                $.ajax({
                    type: "POST",
                    url: "{{ path('commande_editin') }}",
