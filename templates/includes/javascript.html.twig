        // Utilisation de la fonction NumberToLetter
   
    function Unite( nombre ){
        var unite;
        switch( nombre ){
            case 0: unite = "{{ 'zéro'|trans }}";		break;
            case 1: unite = "{{ 'un'|trans }}";		break;
            case 2: unite = "{{ 'deux'|trans }}";		break;
            case 3: unite = "{{ 'trois'|trans }}"; 	break;
            case 4: unite = "{{ 'quatre'|trans }}"; 	break;
            case 5: unite = "{{ 'cinq'|trans }}"; 	break;
            case 6: unite = "{{ 'six'|trans }}"; 		break;
            case 7: unite = "{{ 'sept'|trans }}"; 	break;
            case 8: unite = "{{ 'huit'|trans }}"; 	break;
            case 9: unite = "{{ 'neuf'|trans }}"; 	break;
        }//fin switch
        return unite;
    }//-----------------------------------------------------------------------

