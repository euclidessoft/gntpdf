{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Balance journalière"|trans }} - GNT Pharma {% endblock %}
{% block finance %}active{% endblock %}
{% block journal %}active{% endblock %}
{% block body %}
    <div class="container">
        <div class="container mt-4 mb-5 fond-7 pt-3 pb-3">
            <div class="centrer">
                <a href="{{ path('finance_brouyard_print') }}" class="btn btn-success-light">
                    <i class="fa fa-print"></i>
                    {{ 'imprimer'|trans }}
                </a>
                <span id="exporter"></span>
            </div>
        </div>
        <div class="card border-green shadow-black mt-5 mb-3 fond-5">
            <div class="card-header bg-success-light bb-success">
                <h5 class="text-success fw-bold">
                    <i class="fa-solid fa-chart-simple"></i>
                    {{ 'Balance journalière'|trans }}
                </h5>
            </div>
            <div class="card-body">
                <h4 class="text-success fw-bold mb-4">
                    {{ 'Solde d\'ouverture : '|trans }} {{ ouverture|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                </h4>
                <table class="table table-success-light table-bordered table-hover table-striped" id="liste">
                    <thead>
                    <tr>
                        <th class="text-center"> {{ 'Nº'|trans }}</th>
                        <th class="text-center"> {{ 'Date'|trans }}</th>
                        <th>{{ 'Compte'|trans }}</th>
                        <th>{{ 'Libellé'|trans }}</th>
                        <th class="text-center">{{ 'Débit'|trans }}</th>
                        <th class="text-center">{{ 'Crédit'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% set montant2 = 0 %}
                    {% set i =1 %}
                    {% set transfert = 0 %}
                    {% for ecriture in ecritures %}
                        {% set first = 0 %}
                        {% if ecriture.credit is not null %}
                            {% if ecriture.credit.transfert is not null %}
                                {% set transfert = 1 %}
                            {% endif %}
                            <tr>
                                <td data-label="{{ 'Date'|trans }}" class="text-center">
                                    {% if first == 0 %} {{ i }} {% set i = i + 1 %} {% endif %}
                                </td>
                                <td data-label="{{ 'Date'|trans }}" class="text-center">
                                    {% if first == 0 %}
                                        {{ ecriture.date|date('d/m/Y') }}
                                        {% set first = 1 %}
                                    {% endif %}
                                </td>
                                <td data-label="{{ 'Compte'|trans }}" class="credit">
                                    {{ ecriture.comptedebit }} - {{ ecriture.libellecomptedebit }}
                                </td>
                                <td data-label="{{ 'Libellé'|trans }}">
                                    {{ ecriture.credit ? ecriture.libelle : '' }}

                                </td>
                                <td data-label="{{ 'Crédit'|trans }}" class="text-end">
                                </td>
                                <td data-label="{{ 'Débit'|trans }}" class="text-end">
                                    {{ ecriture.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                                </td>
                            </tr>
                        {% else %}
                            {% if ecriture.debit.transfert is not null %}
                                {% set transfert = 1 %}
                            {% endif %}
                            <tr>
                                <td data-label="{{ 'Date'|trans }}" class="text-center">
                                    {% if first == 0 %} {{ i }} {% set i = i + 1 %} {% endif %}
                                </td>
                                <td data-label="{{ 'Date'|trans }}" class="text-center">
                                    {% if first == 0 %}
                                        {{ ecriture.date|date('d/m/Y') }}
                                        {% set first = 1 %}
                                    {% endif %}
                                </td>
                                <td data-label="{{ 'Compte'|trans }}" class="credit">
                                    {{ ecriture.comptecredit }} - {{ ecriture.libellecomptecredit }}
                                </td>
                                <td data-label="{{ 'Libellé'|trans }}">
                                    {{ ecriture.debit ? ecriture.libelle : '' }}
                                  </td>
                                <td data-label="{{ 'Crédit'|trans }}" class="text-end">
                                    {{ ecriture.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                                </td>
                                <td data-label="{{ 'Débit'|trans }}" class="text-end">

                                </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-success-light bt-success">
                <h4 class="text-success fw-bold">
                    {{ 'Solde : '|trans }}
                    <span class="text-nowrap">
                    {{ (banque+caisse)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} F CFA
                </span>
                </h4>
            </div>
        </div>
    </div>
{% endblock %}