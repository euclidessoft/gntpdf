{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}

{% block title %}{{ 'Compte Resultat'|trans }} - GNT Pharma{% endblock %}

{% block finance %}active{% endblock %}

{% block affectation %}active{% endblock %}

{% block body %}

  <div class="container-fluid mt-4 fond-7">
    <h4 class="mb-5">
        <i class="fa fa-share"></i>
        {{ 'Avantages commerciaux'|trans }} periode du {{ avecom.debut|date("d/m/Y")}} au {{ avecom.fin|date("d/m/Y")}}
    </h4>
    
    {% for message in app.flashes('notice') %}
            <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                {{ message|trans }}
            </div>
        {% endfor %}
        <table class="table table-success-light table-bordered table-hover table-striped mt-3" id="afiichage">
       <thead>
            <tr>
                <th>{{"Client"|trans}}</th>
                <th>{{"C.A."|trans}}</th>
                <th>{{"Achat Comptant"|trans}}</th>
                <th>{{"Commissiom"|trans}}</th>
                <th>{{"Ristourne"|trans}}</th>
                <th>{{"Escompte"|trans}}</th>
                <th>{{"Total"|trans}}</th>
            </tr>
       </thead>
        <tbody>
            {% for periode in periodes %} 
        
                <tr>
                    <td>{{periode.client.nom }}</td>
                    <td>{{periode.ca|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{periode.achat|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{periode.commission|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{periode.ristourne|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{periode.escompte|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                     <td>{{(periode.commission + periode.ristourne + periode.escompte)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                </tr>
            {% else %}
            {% endfor %}
        </tbody>
       </table> 

   
</div>
<div class="container mt-4 mb-5 p-3 fond-7">
        <div class="centrer">
        <a target="__blank" id="print" onclick="load('print')"
               href="{{ path('finance_avantage_show_pdf', {'id' : avecom.id})}}"
               class="btn btn-danger me-2">
                <i class="fa fa-file-pdf"></i>
                {{ "vers Pdf"|trans }}
            </a>

             <span id="exportexcel" class=""></span>
        </div>
    </div>

 
{% endblock %}

