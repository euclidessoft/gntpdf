<!doctype html>
<html lang="{{ app.request.locale }}">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <title> &nbsp; </title>
    <style>
        .titre {
            font-family: Verdana, Geneva, Tahoma, sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #039c4f;
        }

        .text {
            font-size: 14px;
        }

        @media print {
            .table-success-light {
                color: #000 !important;
            }

            .table-bordered {
                border: 1px solid #000 !important;
            }

            thead {
                background-color: #c5fbae !important;
                color: #000;
            }

            .td {
                display: inline-block;
                border: none;
                /*width: 150px !important;*/
            }
        }
    </style>

</head>
<body onload="print()" onafterprint="history.back()">
<div class="container-fluid">
    <div class="col-lg-8 offset-lg-2">
        <div class="row" style="border-bottom: 1px solid #039c4f;padding-bottom: 20px;">
            <div class="col-2">
                <img src="{{ asset('images/gntpharma.jpeg') }}" alt="Logo" class="w-100">
            </div>
            <div class="col-10 text-center">
                <div class="row">
                    <div class="col-12 titre text-center">
                        GNT PHARMA
                    </div>
                    <div class="col-12 text">
                        BP : 3582 Yaoundé – Cameroun, NGOUSSO
                        <br>
                        Montée Éleveur Immeuble Sainte Marie
                    </div>
                    <div class="col-12 text">
                        +237 69 71 49 4 12 / +237 67 52 47 865
                    </div>
                    <div class="col-12 text">
                        info@gntpharma-cameroun.com / www.gnt-pharma.com
                    </div>
                </div>
            </div>
        </div>
        <h3 class="text-center fw-bold text-uppercase my-5">
            {{ 'Balance des tiers | Clients du '|trans }} {{ day1|date('d/m/Y') }} au {{ day2|date('d/m/Y') }}
        </h3>
        <table class="table table-success-light table-bordered table-hover table-striped mt-3" id="affichage">
            <thead>
            <tr>
                <th rowspan="2">{{ "Compte"|trans }}</th>
                <th rowspan="2">{{ "Client"|trans }}</th>
                <th colspan="2">{{ "Mouvements"|trans }}</th>
                <th colspan="2">{{ "Solde"|trans }}</th>
            </tr>
            <tr>
                <th>{{ "Debit"|trans }}</th>
                <th>{{ "Credit"|trans }}</th>
                <th>{{ "Debit"|trans }}</th>
                <th>{{ "Credit"|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for commande in commandes %}

                <tr>
                    <td>{{ commande['compte'] }}</td>
                    <td>{{ commande['nom'] }}</td>
                    <td>{{ commande['ca']|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{ commande['achat']|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    {% set solde = commande['ca'] - commande['achat'] %}
                    <td> {% if solde > 0 %} {{ solde|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} {% endif %}</td>
                    <td> {% if solde < 0 %} {{ (-1 *solde) |number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} {% endif %}</td>

                </tr>
            {% else %}
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
</body>

</html>