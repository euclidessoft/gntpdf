<!doctype html>
<html lang="{{ app.request.locale }}">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <title> &nbsp; </title>
    <style>
        .titre {
            font-family: Verdana, Geneva, Tahoma, sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #039c4f;
        }

        .text {
            font-size: 14px;
        }

        @media print {
            .table-success-light {
                color: #000 !important;
            }

            .table-bordered {
                border: 1px solid #000 !important;
            }

            thead {
                background-color: #c5fbae !important;
                color: #000;
            }

            .td {
                display: inline-block;
                border: none;
                /*width: 150px !important;*/
            }
        }
    </style>

</head>
<body onload="print()" onafterprint="history.back()">
<div class="container-fluid">
    <div class="col-lg-8 offset-lg-2">
        <div class="row" style="border-bottom: 1px solid #039c4f;padding-bottom: 20px;">
            <div class="col-2">
                <img src="{{ asset('images/gntpharma.jpeg') }}" alt="Logo" class="w-100">
            </div>
            <div class="col-10 text-center">
                <div class="row">
                    <div class="col-12 titre text-center">
                        GNT PHARMA
                    </div>
                    <div class="col-12 text">
                        BP : 3582 Yaoundé – Cameroun, NGOUSSO
                        <br>
                        Montée Éleveur Immeuble Sainte Marie
                    </div>
                    <div class="col-12 text">
                        +237 69 71 49 4 12 / +237 67 52 47 865
                    </div>
                    <div class="col-12 text">
                        info@gntpharma-cameroun.com / www.gnt-pharma.com
                    </div>
                </div>
            </div>
        </div>
        <h3 class="mt-4 fw-bold">
            <i class="fas fa-money-bill fa-lg"></i><i class="fas fa-hourglass-half"></i>
           {{ user.compte}} : {{ user.nom ~ " " ~ user.prenom }}
        </h3>
         <h5 class="text-success fw-bold">
            {{ 'du '|trans }} {{ day1|date('d/m/Y') }}
            {{ 'au '|trans }} {{ day2|date('d/m/Y') }}
        </h5>
        <table class="table table-success-light table-bordered table-hover table-striped">
                    <thead>
                    <tr>
                        <th class="text-center"> {{ 'Date'|trans }}</th>
                        <th>{{ 'Libellé'|trans }}</th>
                        <th class="text-center">{{ 'Débit'|trans }}</th>
                        <th class="text-center">{{ 'Crédit'|trans }}</th>
                        {#                        <th class="text-center">{{ 'Solde'|trans }}</th> #}
                    </tr>
                    </thead>
                    <tbody>
                    {% set debit = 0 %}
                    {% set credit = 0 %}
                    {% for commande in commandes %}
                        <tr>
                            <td> {{ commande.date|date("d/m/Y") }}</td>
                            {% if commande.credit is defined %}
                                <td> {{"vente de medicament"|trans}}  Facture: {{ commande.id }}-{{ commande.numerofacture }}</td>
                                <td> {{ commande.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                                <td> </td>
                                 {% set debit = debit + commande.montant %}
                            {% else %}
                                 <td> {{"reglement"|trans}} Facture: {{commande.commande.id }}-{{commande.commande.numerofacture}}</td>
                                <td> </td>
                                <td> {{ commande.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                                 {% set credit = credit + commande.montant %}
                            {% endif %}
                        <tr>
                       
                    {% endfor %}
                    {% set solde = debit - credit %}
                    </tbody>
                    </tfooter>
                        <tr>
                            <th colspan="2" class="text-right">Solde</th>
                            {% if solde > 0 %}
                                <th> {{ solde|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</th>
                                <th> </th>
                            {% elseif solde == 0 %}
                                <th> </th>
                                <th> </th>
                            {% elseif solde < 0  %}
                              <th></th>
                                <th> {{ (-1 * solde)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }} </th>
                            {% endif %}
                        </tr>
                    </tfooter>
                </table>
    </div>
</div>
</body>

</html>