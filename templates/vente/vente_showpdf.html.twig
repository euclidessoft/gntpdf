<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #333;
        }

        /* ── En-tête ── */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #039c4f;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .header-table td { vertical-align: middle; border: none !important; }
        .logo { width: 80px; }
        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #039c4f;
            text-align: center;
        }
        .company-info {
            font-size: 10px;
            text-align: center;
            color: #555;
            line-height: 1.6;
        }

        /* ── Titre facture ── */
        .titre-facture {
            text-align: center;
            font-size: 15px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 16px 0 4px;
        }
        .sous-titre {
            text-align: center;
            font-size: 11px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        /* ── Tableaux ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
        }
        th, td {
            border: none;
            padding: 5px 6px;
            vertical-align: middle;
        }
        thead th {
            background-color: #c5fbae;
            color: #000;
            text-align: center;
            font-size: 10px;
        }
        tbody tr:nth-child(even) td {
            background-color: #f2f2f2;
        }
        td { font-size: 10px; }

        /* ── Tableau récap commande ── */
        .recap-wrapper {
            width: 75%;
            margin: 0 0 20px auto;
        }
        .recap-wrapper td { text-align: center; border: none; }

        /* ── Badge UG ── */
        .badge {
            background-color: #cc0000;
            color: #fff;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 9px;
            font-weight: bold;
        }

        /* ── Totaux ── */
        .text-end { text-align: right; }
        .text-center { text-align: center; }
        .fw-bold { font-weight: bold; }
        .text-nowrap { white-space: nowrap; }

        /* ── Montant en lettres ── */
        .montant-lettres {
            margin: 20px 0;
            font-size: 11px;
            line-height: 1.6;
        }

        /* ── Pied de page ── */
        .footer {
            margin-top: 30px;
            font-size: 9px;
            color: #888;
            text-align: center;
            border-top: 1px solid #ccc;
            padding-top: 8px;
        }
    </style>
</head>
<body>

{# ── En-tête société ── #}
<table class="header-table">
    <tr>
        <td style="width:90px;">
              {% if logoBase64 %}
    <img src="{{ logoBase64 }}" alt="Logo" style="width:80px;">
{% endif %}
        </td>
        <td style="text-align:center;vertical-align:middle;">
            <div class="company-name">GNT PHARMA</div>
            <div class="company-info">
                BP : 3582 Yaoundé – Cameroun, NGOUSSO<br>
                Montée Éleveur Immeuble Sainte Marie<br>
                +237 69 71 49 412 &nbsp;-&nbsp; +237 67 52 47 865<br>
                info@gnt-pharma.com &nbsp;-&nbsp; www.gnt-pharma.com<br>
                RCCM N° : RC/YAE/2023/M/105 &nbsp;-&nbsp; NIU : M122217881373Q
            </div>
        </td>
    </tr>
</table>

<div class="titre-facture"> {{ "Palmares des ventes"|trans }}</div>
   
     <table>
        <thead>
        
       <tr>
            <th>{{ produit.reference }}</th>
            <th>{{ produit.desigantion }}</th>
            <th>{{ produit.dci }}</th>
            <th>{{ produit.fabriquant }}</th>
        </tr
        <tr>
        <td colspan="4"></td>
        </tr>
         <tr>
            <th colspan="2"  class="text-center"><b>{{ "Quantité Totale Vendue"|trans}}: {{ quantite|number_format(0, '', ' ') }} ---> </b>  <b>{{ "U.G"|trans}}: {{ totalug|number_format(0, '', ' ') }}</b></th>
            <th colspan="2"  class="text-center"><b>{{ "Chiffre d'affaire"|trans}}: {{ montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</b></th>
        </tr>
        </thead>
        
    </table>
   

    <table>
        <thead>
        
        <tr>
            <th>{{ 'Date'|trans }}</th>
            <th>{{ 'commande'|trans }}</th>
            <th>{{ 'Quantité vendue'|trans }}</th>
            <th>{{ 'U.G'|trans }}</th>
        </tr>
        </thead>
        <tbody>
        {% set tug = 0 %}
        {% for produit in ventes %}
            <tr>
                <td>{{ produit.commande.date|date("d/m/Y") }}</td>
                <td>
                 <a id="b{{ produit.commande.id }}" onclick="load('b{{ produit.commande.id }}')" href="{{ path('commande_panier_bon', {'commande' : produit.commande.id}) }}" class="btn btn-success">
                 {{ produit.commande.id }}
                </a>
                </td>
                <td>{{ produit.quantite|number_format(0,',' , ' ') }}</td>
                 <td>
                {% set ug = 0 %}
                {% set commande = produit %}
                 {{ commande.ug != 0 ? commande.ug : "" }}
                                    {% set tug = tug + commande.ug %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
        <tr>
            <th colspan="2"  class="text-center">{{ "Quantité Totale Vendue"|trans}}: {{ quantite|number_format(0, '', ' ') }}</th>
            <th  class="text-center">{{ "Chiffre d'affaire"|trans}}: {{ montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</th>
            <th  class="text-center">{{ "U.G"|trans}}: {{ tug|number_format(0, '', ' ') }}</th>
        </tr>
    </table>
</body>
</html>
