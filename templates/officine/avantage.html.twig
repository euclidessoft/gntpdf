{% extends
   
    'client.html.twig'
%}

{% block title %} {{ "Officine"|trans }} - GNT Pharma {% endblock %}
{% block officine %}active{% endblock %}

{% block body %}

  <div class="container-fluid mt-4 fond-7">
   <h3 class="mt-4 mb-5 fw-bold">
            <i class="fas fa-staff-snake fa-lg"></i>
            {{ "Officine"|trans }} :   {{ 'Avantages commerciaux'|trans }}
        </h3>
    <ul class="nav nav-tabs mb-4">
    {% if is_granted("ROLE_CLIENT_ADMIN") %}
            <li class="nav-item">
                <a class="nav-link" href="{{ path('commande_panier_officine') }}">{{ 'Facture'|trans }}</a>
            </li>
     {% endif %}       
            <li class="nav-item">
                <a class="nav-link" href="{{ path('avoir_officine') }}">{{'Avoir'|trans}}</a>
            </li>
     {% if is_granted("ROLE_CLIENT_ADMIN") %}
            <li class="nav-item">
                <a class="nav-link active" href="#">{{'Avantages'|trans}}</a>
            </li>
    {% endif %}
            <li class="nav-item">
                <a class="nav-link" href="{{ path('commande_panier_credit') }}">{{'Dette'|trans}}</a>
            </li>
        </ul>
    {% for message in app.flashes('notice') %}
            <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                {{ message|trans }}
            </div>
        {% endfor %}
        <table class="table table-success-light table-bordered table-hover table-striped mt-3" id="liste">
       <thead>
            <tr>
                <th>{{"Période"|trans}}</th>
                <th>{{"C.A."|trans}}</th>
                <th>{{"Achat Comptant"|trans}}</th>
                <th>{{"Commission"|trans}}</th>
                <th>{{"Ristourne"|trans}}</th>
                <th>{{"Escompte"|trans}}</th>
                <th>{{"total"|trans}}</th>
            </tr>
       </thead>
        <tbody>
            {% for avantage in avantages %} 
        
                <tr>
                    <td>{{avantage.AveCom.debut|date("d/m/Y") }} - {{avantage.AveCom.fin|date("d/m/Y") }}</td>
                    <td>{{avantage.ca|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{avantage.achat|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{avantage.commission|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{avantage.ristourne|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{avantage.escompte|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{(avantage.commission + avantage.ristourne + avantage.escompte)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                </tr>
            {% else %}
            {% endfor %}
        </tbody>
       </table> 
<div class="container mt-4 mb-5 p-3 fond-7">
        <div class="centrer">
        <a target="__blank" id="print" onclick="load('print')"
               href="{{ path('finance_avantage_client_pdf')}}"
               class="btn btn-danger me-2">
                <i class="fa fa-file-pdf"></i>
                {{ "vers Pdf"|trans }}
            </a>

             <span id="exportexcel" class=""></span>
        </div>
    </div>
   
</div>

 
{% endblock %}

