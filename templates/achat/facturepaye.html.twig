{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Commande"|trans }} - GNT Pharma {% endblock %}
{% block finance %}active{% endblock %}
{% block achat %}active{% endblock %}
{% block new_achat %}active{% endblock %}

{% block body %}
    <div class="container mt-4 fond-7">
    <h3 class="mt-4 mb-2 text-bold">
        <i class="fas fa-chart-line me-2"></i>
        {{ "Analyse Fournisseur"|trans }} | {{ fournisseur.designation}} 
    </h3>
        <h3 class="mb-5 text-bold">
            <i class="fa fa-money-bill me-2"></i>
            {{ "Liste des factures payées"|trans }}
        </h3>
        <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link" href="{{ path('vente_chiffre_fourniseur', {'fournisseur': fournisseur.id}) }}">
                {{ "Chiffre d'Affaire"|trans }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('vente_fournisseur_article',{'fournisseur' :fournisseur.id}) }}">
                {{'Articles'|trans}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" href="#">
                {{'Fcature Payees'|trans}}
            </a>
        </li>  
        <li class="nav-item">
            <a class="nav-link" href="{{ path('facture_impaye', {'fournisseur' : fournisseur.id})}}">
                {{'Facture impayees'|trans}}
            </a>
        </li>  
        <li class="nav-item">
            <a class="nav-link" href="{{ path('finance_journal_fournisseur', {'fournisseur' : fournisseur.id})}}">
                {{'Compte'|trans}}
            </a>
        </li>
    </ul>
        {% for message in app.flashes('notice') %}
            <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                {{ message|trans }}
            </div>
        {% endfor %}

        <table class="table table-success-light table-bordered table-hover table-striped w-100 text-center" id="liste">
            <thead>
            <tr>
                <th>{{ 'No Appr'|trans }}</th>
                <th>{{ 'Date'|trans }}</th>
                <th class="text-start">{{ 'Fournisseur'|trans }}</th>
                <th class="text-center">{{ 'Montant'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for approv in approvisionnements %}
                <tr>
                    <td>{{ approv.approvisionner.id }}</td>
                    <td>{{ approv.approvisionner.date|date('d/m/Y') }}</td>
                    <td class="text-start">{{ approv.fournisseur ? approv.fournisseur.designation : '' }}</td>
                    <td class="text-start">{{ approv.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
