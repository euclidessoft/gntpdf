{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Nouvelle absence"|trans }} - GNT Pharma {% endblock %}
{% block discipline %}active{% endblock %}
{% block employe %}active{% endblock %}
{% block depense %}active{% endblock %}
{% block absence_index  %}active{% endblock %}

{% block body %}
    <div class="col-lg-4 offset-lg-4 v-center">
    {{ include('absence/admin/_form.html.twig') }}
    <div class="col mb-5 p-3 fond-7">
        <div class="centrer gap-3">
            <button type="button" class="btn btn-shadow btn-green btn-normal" id="send"
                    onclick="envoie()">
                <i class="fa fa-save"></i>
                {{ 'Enregistrer'|trans }}
            </button>

            <button type="button" class="btn btn-shadow btn-success-light btn-normal" onclick="history.back()">
                <i class="fa fa-undo"></i>
                {{ 'Retour'|trans }}
            </button>
            {{ form_rest(form) }}
        </div>
    </div>

    {{ form_end(form) }}
    </div>
{% endblock %}
