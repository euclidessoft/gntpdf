{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Voir les avoir"|trans }} - GNT Pharma {% endblock %}
{% block officine %}active{% endblock %}
{% block all_avoir %}active{% endblock %}
{% block client_suivi %}active{% endblock %}


{% block body %}
    <div class="container mt-4 fond-7">
        <h3 class="mt-4 mb-5 fw-bold">
            <i class="fa fa-money-bill me-2"></i>
            {{ "Listes des avoirs"|trans }}
        </h3>

        {% for message in app.flashes('notice') %}
            <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                {{ message|trans }}
            </div>
        {% endfor %}

        <a class="btn btn-green mb-5" href="{{ path('avoir_choix') }}">
            <i class="fa-solid fa-sack-dollar"></i><i class="fa fa-plus"></i>
            {{ 'Créer avoir'|trans }}
        </a>

        <table class="table table-success-light table-bordered table-hover table-striped my-3" id="liste">
            <thead>
            <tr>
                <th>{{ 'Date'|trans }}</th>
                <th>{{ 'Client'|trans }}</th>
                <th>{{ 'Montant'|trans }}</th>
                <th>{{ 'Créer par'|trans }}</th>
                <th>{{ 'Motif'|trans }}</th>
                <th>{{ 'Actions'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for avoir in avoirs %}
                <tr>
                    <td>{{ avoir.date ? avoir.date|date('d/m/Y') : '' }}</td>
                    <td>{{ avoir.client.nom }}</td>
                    <td>{{ avoir.Montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{ avoir.admin.prenom }} {{ avoir.admin.nom }}</td>
                    <td>
                        {{ avoir.reste?"Reste à livré":'' }}
                        {{ avoir.reclamation?"Reclamation":'' }}
                        {{ avoir.retour?"Retour produit":'' }}
                    </td>
                    <td>
                        <a id="{{ avoir.id }}" onclick="load({{ avoir.id }})" class="btn btn-green"
                           href="{{ path('avoir_show', {'id': avoir.id}) }}">
                            <i class="fa fa-list"></i>
                            {{ 'Afficher'|trans }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
