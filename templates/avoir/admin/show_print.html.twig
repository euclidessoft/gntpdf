<!doctype html>
<html lang="en">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <title>&nbsp;</title>
    <style>
        .titre {
            font-family: Verdana, Geneva, Tahoma, sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #039c4f;
        }

        .text {
            font-size: 14px;
        }

        .badge {
            background-color: red !important;
        }

        @media print {
            .table-success-light {
                color: #000 !important;
            }

            .table-bordered {
                border: 1px solid #000 !important;
            }

            thead {
                background-color: #c5fbae !important;
                color: #000;
            }

            .tt {
                display: inline-block;
                border: none;
                width: 180px !important;
            }
        }
    </style>

</head>

<body onload="print()" onafterprint="history.back()">
    <div class="container-fluid">



        <div class="col-lg-8 offset-lg-2">
            <div class="row" style="border-bottom: 1px solid #039c4f;padding-bottom: 20px;">
                <div class="col-2">
                    <img src="{{ asset('images/gntpharma.jpeg') }}" alt="Logo" class="w-100">
                </div>
                <div class="col-10 text-center">
                    <div class="row">
                        <div class="col-12 titre text-center">
                            GNT PHARMA
                        </div>
                        <div class="col-12 text">
                            BP : 3582 Yaoundé – Cameroun, NGOUSSO
                            <br>
                            Montée Éleveur Immeuble Sainte Marie
                        </div>
                        <div class="col-12 text">
                            +237 69 71 49 4 12 / +237 67 52 47 865
                        </div>
                        <div class="col-12 text">
                            info@gntpharma-cameroun.com / www.gnt-pharma.com
                        </div>
                    <div class="col-12 text">
                        RCCM N° : RC/YAE/2023/M/105 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;NIU : M122217881373Q
                    </div>
                    {# <div class="col-12 text">
                       SARL au CAPITAL de 100 000 000 F CFA
                    </div> #}
                        <!-- <div class="col-12 fw-bold">

                </div> -->
                    </div>
                </div>
            </div>
            {% set commande = avoir.commande %}
           <h3 class="text-center fw-bold text-uppercase mt-4">
            {{ 'Facture Avoir'|trans }}
        </h3>
        <h6 class="text-center fw-bold text-uppercase mb-3">
        {{ 'Numero'|trans }} : {{ commande.id}}-{{ commande.numerofacture }}-{{ avoir.id}}
        </h6>

            <div class="row">
            <div class="col-12">
                    <table class="table table-success-light table-bordered table-hover table-striped">
                    <thead>
                    <tr>
                        <th>{{ 'N° Commande'|trans }}</th>
                        <th>{{ 'Date Commande'|trans }}</th>
                        <th>{{ 'Date Traitement'|trans }}</th>
                        <th>{{ 'Client'|trans }}</th>
                         <th>{{ 'NIU'|trans }}</th>
                         <th>{{ 'RCCM'|trans }}</th>
                        {% if commande.credit == 1 and commande.payer == 0 %}
                        <th>{{ 'date d\'echeance de paiement'|trans }}</th>
                        {% endif %}
                        {# <th>{{ 'Status Commande'|trans }}</th> #}
                        {#            <th>Date de Livraison</th>#}
                    </tr>
                    </thead>
                    <tbody>
                    <td>{{ commande.id }}</td>
                    <td>{{ commande.date|date('d/m/Y H:is') }}</td>
                    <td>{{ commande.traitement|date('d/m/Y H:i:s') }}</td>
                     <td>{{ commande.user.nom ~ " " ~ commande.user.prenom }}</td>
                     <td>{{ commande.user.niu }}</td>
                     <td>{{ commande.user.rccm }}</td>
                         {% if commande.credit == 1 and commande.payer == 0 %}
                             <td> {{ commande.echeance ? commande.echeance|date('d/m/Y'): ''  }}</td>
                        {% endif %}
                    {#        <td> </td>#}
                    </tbody>
                </table>
                </div>
            </div>
            {% set total=0 %}
            {% set reduction=0 %}
            {% set tva=0 %}
            <table class="table table-success-light table-bordered table-hover table-striped w-100 my-4">
            <thead>
            <tr>
                <th>{{ 'CIP'|trans }}</th>
                <th>{{ 'Désignation'|trans }}</th>
                {# <th>{{ 'DCI'|trans }}</th> #}
                <th>{{ 'Quantité Retournée'|trans }}</th>
                {#            <th>Quantite Restante</th>#}
                <th>{{ 'Prix Cession'|trans }}</th>
                <th>{{ 'TVA'|trans }}</th>
                <th>{{ 'Prix Public'|trans }}</th>
                <th>{{ 'Montant'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for commandeproduit in commandeproduits %}
                {% set ug = 0 %}
                {% set reductionproduit = 0 %}
                <tr>
                    <td> {{ commandeproduit.produit.reference }} </td>
                    <td>{{ commandeproduit.produit.desigantion }} </td>
                    {# <td>{{ commandeproduit.produit.dci }} </td> #}
                    <td>
                       - {{ commandeproduit.quantite }}
                     
                    </td>
                    {#                <td> </td>#}
                    <td class="montant noExport">
                        - {{ commandeproduit.prix|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}

                    </td>
                    <td>
                        {{ commandeproduit.tva != 0 ? commandeproduit.tva : '' }}
                        {% set tva = tva + commandeproduit.tva %}
                           
                    </td>
                    <td class="montant">{{ commandeproduit.prixpublic|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td class="montant">
                        - {{ (commandeproduit.quantite * commandeproduit.prix)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}
                        {% set total = total + (commandeproduit.quantite * commandeproduit.prix) %}
                    </td>
                </tr>
            {% endfor %}
            <tbody>
            <tfoot>
            <tr>
                <td colspan="6" class="text-end">
                    {{ "Total HT"|trans }}
                </td>
                <td class="montant">
                    <span id="" class="text-nowrap">- {{ total|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                </td>
            </tr>
            <tr>
                <td colspan="6" class="text-end">
                    {{ "Total TVA"|trans }}
                </td>
                <td class="montant">
                    <span id="" class="text-nowrap">- {{ avoir.tva|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                </td>
            </tr>
            <tr>
                <td colspan="6" class="text-end">
                    {{ "Prélèvement (2%)"|trans }}
                </td>
                <td class="text-center">
               
                    <span id="">{{ avoir.prelevement != 0 ? avoir.prelevement|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') : ''}}</span>
                    
                </td>
            </tr>

            <tr class="fw-bold">
                <td colspan="6" class="text-end">
                    {{ "Net à payer"|trans }}
                </td>
                <td class="montant">
                    <span class="text-nowrap">- {{ avoir.montant|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</span>
                          <span id="total" class="text-nowrap" style="display:none;">{{ (total  + tva)|number_format(2, '.' , '') }}</span>
                </td>
            </tr>
            </tfoot>
        </table
            {#Conversion prix en lettre #}
            <div class="mt-5">
                {{ 'Arrêtée la présente à la somme de '|trans}} <b id="conversion"></b><b id="virgule"></b> <b>franc CFA TTC</b>
            </div>
            {#/***** end*****/#}
            {{ include('includes/javascript.html.twig') }}

</body>

</html>