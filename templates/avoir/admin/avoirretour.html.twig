{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block title %} {{ "Livraison"|trans }} - GNT Pharma {% endblock %}
{% block officine %}active{% endblock %}
{% block new_avoir %} active {% endblock %}
{% block client_suivi %}active{% endblock %}

{% block body %}
    <div class="container mt-4 fond-7">
        <h3 class="mt-4 mb-5 fw-bold">
            <i class="fa fa-money-bill me-2"></i>
            {{ "Création Avoir à partie des Retours de produits"|trans }}
        </h3>
          {% for message in app.flashes('notice') %}
            <div role="alert" class="alert alert-success alert-dismissible fade show radius-10 shadow-black">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                {{ message|trans }}
            </div>
        {% endfor %}
        <div class="row">
            <div class="col-lg-12">
                <table class="table table-success-light table-bordered table-hover table-striped w-100" id="liste">
                    <thead>
                    <tr>
                        <th>{{ 'no commande'|trans}}</th>
                        <th>{{ 'Date'|trans }}</th>
                        <th>{{ 'Client'|trans }}</th>
                        <th>{{ 'actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for retour in retours %}
                        <tr>
                            <td>{{ retour.commande.id }}</td>
                            <td>{{ retour.commande.date|date('d/m/Y') }}</td>
                            <td>{{ retour.commande.user.nom }}</td>
                            <td>
                                <button id="avoir{{ retour.id }}" onclick="retour_creer_avoir({{ retour.id }})" class="btn btn-success">
                                 <i class="fa fa-money-bill"></i> {{ 'Creer Avoir'|trans }}
                                </button>
                            </td>
                            
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
{% block scripts %}
    <script>
  function retour_creer_avoir(id) {

            if (confirm("voulez-vous vraiment?")) {
                $("#avoir" + id).html("<i class='fa-solid fa-spinner fa-spin-pulse'></i>");
                $("#avoir"+ id).addClass('disabled');
                $.ajax({
                    type: "POST",
                    url: "{{ path('avoir_new_retour') }}",
                    data: {retour: id},
                    success: function (data) {
                        if (data['id'] == 'ok') {
                               document.location.href="{{ path('avoir_retour') }}";
                                }
                    },
                    error: function () {
                        alert("{{ 'La requête n’a pas abouti'|trans }}");
                    }
                });
            }
        }
</script>
{% endblock %}
