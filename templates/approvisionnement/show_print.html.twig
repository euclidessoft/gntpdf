<!doctype html>
<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <title>	&nbsp;</title>
    <style>
        .titre {
            font-family: Verdana, Geneva, Tahoma, sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #039c4f;
        }

        .text {
            font-size: 14px;
        }

        .badge {
            background-color: red !important;
        }

        @media print {
            .table-success-light {
                color: #000 !important;
            }

            .table-bordered {
                border: 1px solid #000 !important;
            }

            thead {
                background-color: #c5fbae !important;
                color: #000;
            }

            .tt {
                display: inline-block;
                border: none;
                width: 180px !important;
            }
        }
    </style>

</head>
<body onload="print()" onafterprint="document.location.href='{{ path('stock_historique') }}' ">
<div class="container-fluid">


    <div class="col-lg-8 offset-lg-2">
        <div class="row" style="border-bottom: 1px solid #039c4f;padding-bottom: 20px;">
            <div class="col-2">
                <img src="{{ asset('images/gntpharma.jpeg') }}" alt="Logo" class="w-100">
            </div>
            <div class="col-10 text-center">
                <div class="row">
                    <div class="col-12 titre text-center">
                        GNT PHARMA
                    </div>
                    <div class="col-12 text">
                        BP : 3582 Yaoundé – Cameroun, NGOUSSO
                        <br>
                        Montée Éleveur Immeuble Sainte Marie
                    </div>
                    <div class="col-12 text">
                        +237 69 71 49 4 12 / +237 67 52 47 865
                    </div>
                    <div class="col-12 text">
                        info@gntpharma-cameroun.com / www.gnt-pharma.com
                    </div>
                    <!-- <div class="col-12 fw-bold">

                    </div> -->
                </div>
            </div>
        </div>
        <h3 class="text-center fw-bold text-uppercase my-5">
            {{ 'Details Approvisionnement'|trans}}
        </h3>

        <div class="row justify-content-end">
            <div class="col-lg-5">
                <table class="table table-success-light table-bordered">
                    <thead>
                    <tr>
                        <th>{{ 'Numéro'|trans }}</th>
                        <th>{{ 'Date'|trans }}</th>
                        <th>{{ 'Utilisateur'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <td>{{ approvisionner.id }}</td>
                        <td>{{ approvisionner.date|date('d/m/Y') }}</td>
                        <td>{{ approvisionner.user.prenom }} {{ approvisionner.user.nom }}</td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>
        {% set total=0 %}
        <table class="table table-success-light table-bordered table-hover table-striped w-100 text-center mt-5">
            <thead>
            <tr>
                <th>{{ 'CIP'|trans }}</th>
                <th class="text-start">{{ 'Désignation'|trans }}</th>
                <th>{{'Fournisseur'|trans}}</th>
                <th>{{'N° Lot'|trans}}</th>
                <th>{{'Péremption'|trans}}</th>
                {#            <th>etat stosk</th>#}
                <th>{{'Quantité'|trans}}</th>
                <th>{{'PGHT'|trans}}</th>
                <th>{{'PGHT Total'|trans}}</th>
                <th>{{'P. Cession'|trans}}</th>
                <th>{{'P. Cession Total'|trans}}</th>
            </tr>
            </thead>
            <tbody>
            {% set pght = 0 %}
            {% set pghtproduit = 0 %}
            {% set cession = 0 %}
            {% set cessionproduit = 0 %}
            {% for approvisionnement in approvisionnements %}
                <tr>
                    <td> {{ approvisionnement.produit.reference }} </td>
                    <td class="text-start"><a href="{{ path('produit_show', {'id': approvisionnement.produit.id}) }}">{{ approvisionnement.produit.desigantion }}</a> </td>
                    <td>{{ approvisionnement.fournisseur ? approvisionnement.fournisseur.designation : 'Retour Produit'}} </td>
                    <td>{{ approvisionnement.lot }} </td>
                    <td>{{ approvisionnement.peremption|date('d/m/Y') }} </td>
                    {#                <td> {{ approvisionnement.produit.stock }} </td>#}
                    <td>{{ approvisionnement.quantite }}</td>
                    <td>{{ approvisionnement.pght|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{ (approvisionnement.pght * approvisionnement.quantite)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',')}}</td>
                    <td>{{ approvisionnement.cession|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</td>
                    <td>{{ (approvisionnement.cession * approvisionnement.quantite)|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',')}}</td>
            {% set pght = pght + approvisionnement.pght %}
            {% set pghtproduit = pghtproduit + approvisionnement.pght * approvisionnement.quantite %}
            {% set cession = cession + approvisionnement.cession %}
            {% set cessionproduit = approvisionnement.cession * approvisionnement.quantite %}


                </tr>

            {% else %}
              
            {% endfor %}
            </tbody>
            <tfooter>
                <tr>
                    <th colspan="6">Totaux</th>
                    <th>{{ pght|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</th>
                    <th>{{ pghtproduit|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</th>
                    <th>{{ cession|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</th>
                    <th>{{ cessionproduit|number_format(2, app.request.locale == 'fr' ? ',' : '.', app.request.locale == 'fr' ? ' ' : ',') }}</th>
                </tr>
            </tfooter>
        </table>
    </div>
</div>
</body>

</html>
