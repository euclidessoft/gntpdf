{% extends
    is_granted('ROLE_ADMIN') ? 'admin.html.twig' :
    is_granted('ROLE_SUPERVISEUR') ? 'admin.html.twig' :
    is_granted('ROLE_RH') ? 'rh.html.twig' :
    is_granted('ROLE_FINANCE') ? 'finance.html.twig' :
    is_granted('ROLE_CAISSIER') ? 'caisse.html.twig' :
    is_granted('ROLE_STOCK') ? 'stock.html.twig' :
    is_granted('ROLE_LIVREUR') ? 'livreur.html.twig' :
    is_granted('ROLE_EMPLOYER') ? 'employe.html.twig' :
    is_granted('ROLE_LABORATOIRE') ? 'laboratoire.html.twig' :
    'layout.html.twig'
%}
{% block body %}
<div class="container mt-5 mb-5 p-5 fond-7">
    <h4 class="fw-bold mb-5">
        <i class="fa fa-user me-2"></i>
        {{ 'Profil utilisateur'|trans }}
    </h4>
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link" href="{{ path('security_profile') }}">
                {{'Informations'|trans }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" href="#">
                {{'Professionnelles'|trans}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('security_change_password') }}">
                {{'Securite'|trans}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('evaluation_suivi') }}">
                {{'Discipline'|trans}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('mes_bulletins') }}">
                {{'Bulletins'|trans}}
            </a>
        </li>
    </ul>
    <div class="row">
        {% set employe = app.user %}
        <div class="col-md-8 pt-5">
            <p><strong>Matricule : </strong>{{ employe.matricule }}</p>
            <p><strong>Date d'embauche : </strong>{{ employe.hireDate ? employe.hireDate|date('d/m/Y'): ' ' }}</p>
            <p><strong>Poste : </strong>{{ employe.poste.nom }}</p>
            <p><strong>Departement : </strong>{{ employe.poste.departement.nom }}</p>
            <p><strong>Niveau d'accés : </strong>{{ employe.fonction }}</p>
            <p><strong>Salaire : </strong>{{ employe.poste.salaire }} FCFA</p>
        </div>
    </div>
    {% endblock %}