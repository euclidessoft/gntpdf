{% extends 'client.html.twig' %}
{% block title %} {{ 'Changement mot de passe'|trans }} - GNT Pharma {% endblock %}
{% block officine %}active{% endblock %}
{% block clients %}active{% endblock %}
{% block body %}

    <div class="row">
        <div class="col-lg-12">
            <div class="col-lg-6 offset-lg-3 mt-5 mb-5 pb-2 fond-7">
                <h4 class="mt-4 mb-5 fw-bold">
                    <i class="fa fa-lock"></i>
                    {{ 'Changement mot de passe'|trans }}
                </h4>
                <div class="col-lg-8 offset-lg-2">
                    {{ form_start(form) }}
                    <div class="form-group mt-4">
                        {% if form_errors(form) %}
                            {{ form_errors(form) }}
                        {% endif %}
                        {{ form_row(form.test, { 'attr' : { 'placeholder' : 'Mot de passe actuel', 'autofocus':'autofocus'}, 'label': 'Mot de passe actuel'}) }}
                    </div>
                    <div class="form-group mt-4">
                        {{ form_row(form.password, { 'attr' : { 'placeholder' : 'Nouveau mot de passe'}, 'label': 'Nouveau mot de passe'}) }}
                    </div>
                    <div class="form-group mt-4 mb-5">
                        {{ form_row(form.confirm, { 'attr' : { 'placeholder' : 'Confirmer mot de passe'}, 'label': 'Confirmer mot de passe'}) }}
                    </div>
                    <div class="row">
                        <div class="centrer gap-3">
                            <button type="submit" class="btn btn-shadow btn-normal btn-success">
                                <i class="fa fa-save"></i>
                                {{ 'Enregistrer'|trans }}
                            </button>
                            <a id="annule" onclick="load('annule')" href="{{ path('security_profile')}}" class="btn btn-shadow btn-normal btn-success-light">
                                <i class="fa fa-undo"></i>
                                {{ 'Annuler'|trans }}
                            </a>
                            {{ form_rest(form) }}
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
